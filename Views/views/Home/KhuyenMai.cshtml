@model IEnumerable<WebQuanLiCuaHangTapHoa.Models.SanPham>


@{
    ViewBag.Title = "Sản phẩm khuyến mãi";
    Layout = "~/Views/Shared/_LayoutUser.cshtml";
}

<section class="py-4">
    <div class="container">
        <h2 class="mb-4 text-success fw-bold"><i class="bi bi-fire me-2"></i>Sản phẩm đang khuyến mãi</h2>

        <!-- Lưới sản phẩm -->
        <div class="row g-4">
            @foreach (var sp in Model)
            {
                <div class="col-12 col-sm-6 col-md-4 col-lg-3">
                    <div class="card product-card h-100 shadow-sm border-0 position-relative">
                        <!-- Huy hiệu khuyến mãi -->
                        <div class="promo-badge">
                            -@(sp.KhuyenMai?.PhanTram ?? 0)%
                        </div>

                        <div class="price-box mb-2">
                            @{
                                var phanTram = sp.KhuyenMai?.PhanTram ?? 0;
                                var giaGiam = sp.GiaBan * (1 - (decimal)phanTram / 100);
                            }
                            <span class="text-danger fw-bold me-2">@string.Format("{0:N0}₫", giaGiam)</span>
                            <small class="text-muted text-decoration-line-through">
                                @string.Format("{0:N0}₫", sp.GiaBan)
                            </small>
                        </div>


                        <!-- Hình ảnh -->
                        <a href="@Url.Action("ChiTiet","SanPham", new { id = sp.MaSP })">
                            <img src="@sp.HinhAnh" class="card-img-top product-img" alt="@sp.TenSP" />
                        </a>

                        <div class="card-body d-flex flex-column">
                            <h6 class="fw-semibold text-truncate mb-2">@sp.TenSP</h6>

                            

                            <div class="mt-auto d-flex gap-2">
                                <a class="btn btn-outline-success btn-sm flex-fill"
                                   href="@Url.Action("ChiTiet","SanPham", new { id = sp.MaSP })">
                                    <i class="bi bi-eye me-1"></i> Xem
                                </a>
                                <a class="btn btn-brand btn-sm flex-fill"
                                   href="@Url.Action("ThemGioHang","GioHang", new { maSP = sp.MaSP, url = Request.Url.ToString() })">
                                    <i class="bi bi-bag-plus me-1"></i> Thêm
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</section>

@section styles{
    <style>
        /* ====== CARD ====== */
        .product-card {
            border-radius: 14px;
            overflow: hidden;
            transition: transform .2s, box-shadow .2s;
        }

            .product-card:hover {
                transform: translateY(-4px);
                box-shadow: 0 10px 24px rgba(0,0,0,0.1);
            }

        .product-img {
            height: 220px;
            object-fit: cover;
        }

        /* ====== BADGE % ====== */
        .promo-badge {
            position: absolute;
            top: 10px;
            left: 10px;
            background: #dc2626;
            color: #fff;
            font-weight: 700;
            font-size: 0.9rem;
            border-radius: 8px;
            padding: 5px 10px;
            box-shadow: 0 2px 6px rgba(0,0,0,0.15);
        }

        /* ====== GIÁ ====== */
        .price-box {
            font-size: 1rem;
        }

        /* ====== BTN ====== */
        .btn-brand {
            background: linear-gradient(135deg,#16a34a,#22c55e);
            color: #fff;
            border: 0;
        }

            .btn-brand:hover {
                filter: brightness(.95);
            }
    </style>
}
