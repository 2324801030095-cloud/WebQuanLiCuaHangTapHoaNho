@{
    Layout = null;                                          // Không kế thừa layout khác (layout gốc)
    var title = ViewBag.Title as string ?? "Thanh Nhan";    // Tiêu đề mặc định nếu ViewBag.Title null
}

<!doctype html>
                                             <!-- Khai báo HTML5 -->
<html lang="vi">
                                            <!-- Ngôn ngữ: tiếng Việt -->
<head>
    <meta charset="utf-8">                                  <!-- Mã ký tự UTF-8 -->
    <meta name="viewport" content="width=device-width, initial-scale=1"> <!-- Responsive -->
    <title>@title - Thanh Nhàn Grocery</title>              <!-- Tiêu đề trang -->
    <!-- ===== CSS Thư viện (CDN) ===== -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />  <!-- Bootstrap 5 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" /> <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css" />             <!-- Swiper CSS v11 (KHỚP JS) -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600&display=swap" rel="stylesheet">   <!-- Google font Inter -->
    <!-- ===== CSS riêng của dự án ===== -->
    <link href='@Url.Content("~/Content/ThanhNhan/Layout.css")?v=@DateTime.UtcNow.Ticks' rel="stylesheet" />

    @RenderSection("styles", required: false)

    <!-- Chỗ cho view con chèn CSS riêng (nếu cần) -->

    <style>
/* ========= Biến theme chung ========= */
:root {
    --g1: #16a34a;
    --g2: #22c55e;
    --gSoft: #f1fff6; /* Màu thương hiệu */
    --text: #0b1320;
    --muted: #64748b; /* Màu chữ */
    --radius: 16px;
    --shadow: 0 12px 32px rgba(2,6,23,.08); /* Bo góc + bóng */
    --gapSection: 3.2rem; /* Spacing vertical */
}

body {
    font-family: 'Inter',system-ui,-apple-system,Segoe UI,Roboto,Arial,sans-serif;
    color: var(--text)
}

html {
    scroll-behavior: smooth
}

/* ========= Header 2 tầng + hiệu ứng thu gọn khi lướt ========= */
.tn-header {
    position: fixed;
    inset: 0 0 auto 0;
    z-index: 1040;
    transition: transform .3s ease,box-shadow .3s ease
}

.tn-topline {
    height: 6px;
    background: #0f4d3a
}
/* Dải màu trên cùng */
.tn-row1 {
    background: rgba(255,255,255,.96);
    box-shadow: 0 2px 12px rgba(2,6,23,.06);
    padding: .6rem 0;
    transition: padding .25s
}

.tn-row2 {
    background: #fff;
    border-bottom: 1px solid #e5e7eb;
    padding: .45rem 0;
    transition: padding .25s
}

.nav-compact .tn-row1 {
    padding: .2rem 0
}
/* Thu gọn khi lướt */
.nav-compact .tn-row2 {
    padding: .2rem 0
}

.nav-hidden {
    transform: translateY(-100%)
}
/* Ẩn hẳn khi kéo xuống */

/* Ô tìm kiếm + nút tìm */
.tn-search-btn {
    background: #fff;
    color: #0f4d3a;
    border: 1px solid #0f4d3a;
    border-radius: 12px;
    min-width: 50px
}

/* Nút “Danh mục” (gradient xanh) + dropdown dạng lưới */
.tn-cat-btn {
    background: linear-gradient(135deg,var(--g1),var(--g2));
    color: #fff;
    border: 0;
    border-radius: 10px;
    padding: .6rem 1rem;
    box-shadow: 0 10px 24px rgba(22,163,74,.22)
}

.tn-cat-menu {
    max-width: min(92vw,880px);
    border-radius: 16px
}

.tn-cat-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit,minmax(220px,1fr));
    gap: 14px
}

    .tn-cat-grid .dropdown-item {
        white-space: normal;
        line-height: 1.25;
        border-radius: 10px;
        padding: .65rem .75rem
    }

        .tn-cat-grid .dropdown-item:hover {
            background: #f0fdf4
        }

/* Menu chính */
.tn-mainnav {
    min-height: 44px
}

.tn-link {
    color: #143d2a;
    text-decoration: none;
    font-weight: 600;
    padding: .25rem
}

    .tn-link:hover {
        color: #0a7f42
    }

/* Nút thương hiệu (CTA) */
.btn-brand {
    background: linear-gradient(135deg,var(--g1),var(--g2));
    border: 0;
    color: #fff
}

    .btn-brand:hover {
        filter: brightness(.96);
        color: #fff
    }

/* ========= Hero (nền xanh nhạt + gradient) ========= */
.hero {
    background: radial-gradient(1200px 420px at 15% -10%, rgba(22,163,74,.18), transparent 60%), radial-gradient(900px 380px at 110% 10%, rgba(34,197,94,.15), transparent 60%), var(--gSoft);
    border-bottom: 1px solid #e2e8f0;
}

    .hero h1 {
        font-size: clamp(1.8rem, 2.4vw + 1.2rem, 3.1rem)
    }

/* ========= Card sản phẩm + progress ========= */
.card-soft {
    background: #fff;
    border: 1px solid #e2e8f0;
    border-radius: var(--radius);
    box-shadow: var(--shadow);
    position: relative
}

.product-card {
    overflow: hidden;
    transition: transform .16s,box-shadow .16s
}

    .product-card:hover {
        transform: translateY(-3px);
        box-shadow: 0 18px 48px rgba(2,6,23,.12)
    }

.product-img {
    height: 220px;
    object-fit: cover
}

@@media(min-width:1200px) {
    .product-img {
        height: 240px
    }
}

.price {
    color: #15803d;
    font-weight: 700;
    font-size: 1.05rem
}

.stock-wrap {
    display: flex;
    align-items: center;
    gap: 12px
}

.stock-bar {
    height: 8px;
    background: #e5e7eb;
    border-radius: 999px;
    overflow: hidden;
    flex: 1
}

    .stock-bar > span {
        display: block;
        height: 100%;
        background: repeating-linear-gradient(45deg,#dc6b4d 0 8px,#d65a3b 8px 16px)
    }

/* ========= Huy hiệu TOP (crown/hot) ========= */
.rank-badge {
    position: absolute;
    left: 12px;
    top: 12px;
    z-index: 2;
    display: flex;
    align-items: center;
    gap: 6px;
    padding: .28rem .48rem;
    border-radius: 999px;
    background: #0b1320cc;
    color: #fff;
    font-weight: 700;
    font-size: .82rem;
    backdrop-filter: blur(6px);
    box-shadow: 0 6px 18px rgba(0,0,0,.12)
}

    .rank-badge .ico {
        width: 22px;
        height: 22px;
        display: grid;
        place-items: center;
        border-radius: 50%
    }

.rank-1 .ico {
    background: conic-gradient(#ffdd55,#ffc700,#ff8a00)
}

.rank-2 .ico {
    background: conic-gradient(#e5e7eb,#cbd5e1,#94a3b8)
}

.rank-3 .ico {
    background: conic-gradient(#f3e8ff,#d8b4fe,#a78bfa)
}

.rank-hot .ico {
    background: conic-gradient(#ffe4e6,#fecaca,#f87171)
}

.rank-badge small {
    opacity: .9
}

/* ========= USP (icon tròn) ========= */
.usp .icon {
    width: 54px;
    height: 54px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg,#c6f6d5,#eafff3);
    color: #15803d;
    box-shadow: 0 6px 22px rgba(34,197,94,.18)
}

/* ========= Promo slider ========= */
.promo-slide {
    border-radius: 28px;
    overflow: hidden;
    border: 1px solid #e2e8f0;
    box-shadow: var(--shadow);
    background: #fff
}

.promo-cover {
    border-radius: 18px
}

/* ========= Section nền be ========= */
.section-alt {
    background: #f6f4ec
}

/* ========= Footer ========= */
.app-footer {
    background: radial-gradient(1200px 420px at 15% -10%, rgba(22,163,74,.18), transparent 60%), radial-gradient(900px 380px at 110% 10%, rgba(34,197,94,.15), transparent 60%), var(--gSoft);
    color: #1f2937;
    border-top: 1px solid #e2e8f0
}

    .app-footer a {
        color: #0f172a;
        text-decoration: none
    }

        .app-footer a:hover {
            color: #065f46;
            text-decoration: underline
        }

.footer-bottom {
    border-top: 1px solid rgba(2,6,23,.08);
    color: #334155
}

/* ========= Spacing chung ========= */
section {
    padding: var(--gapSection) 0
}

/* ========= Back-to-top ========= */
.backtop {
    position: fixed;
    right: 16px;
    bottom: 16px;
    z-index: 1050;
    width: 46px;
    height: 46px;
    border-radius: 50%;
    background: linear-gradient(135deg,var(--g1),var(--g2));
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 10px 30px rgba(22,163,74,.35);
    cursor: pointer;
    display: none
}

/* ========= Swiper tối ưu ========= */
.swiper-slide {
    will-change: transform
}

.swiper-pagination-bullet {
    opacity: .5
}

.swiper-pagination-bullet-active {
    opacity: 1;
    box-shadow: 0 2px 10px rgba(0,0,0,.15)
}

/* ========= TOP CAROUSEL: “peek” hai bên + flip ========= */
#topCarousel.swiper, #topCarousel .swiper-wrapper {
    overflow: visible
}
/* Cho slide ló ra ngoài */
.top-slide {
    width: clamp(280px,62vw,520px);
    height: 320px;
    filter: drop-shadow(0 10px 26px rgba(2,6,23,.18));
    border-radius: 18px
}

#topCarousel .swiper-slide {
    transition: transform .35s ease, opacity .35s ease;
    opacity: .75
}

#topCarousel .swiper-slide-active {
    transform: scale(1.02);
    opacity: 1
}

/* Flip card (mặt trước/ sau) */
.flip {
    perspective: 1200px;
    height: 100%
}

.flip-inner {
    position: relative;
    width: 100%;
    height: 100%;
    transform-style: preserve-3d;
    transition: transform .6s cubic-bezier(.2,.7,.2,1);
    border-radius: 18px;
    overflow: hidden
}

.flip.is-flipped .flip-inner {
    transform: rotateY(180deg)
}

.flip-face {
    position: absolute;
    inset: 0;
    backface-visibility: hidden;
    border-radius: 18px;
    overflow: hidden
}

.flip-front img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block
}

.flip-front::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg,transparent,rgba(0,0,0,.25))
}

.flip-back {
    transform: rotateY(180deg);
    background: #0b1320;
    color: #fff;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    padding: 24px;
    text-align: center
}

    .flip-back h6 {
        margin-bottom: .5rem
    }

    .flip-back p {
        opacity: .9;
        line-height: 1.5
    }

.flip-hint {
    position: absolute;
    right: 12px;
    bottom: 12px;
    background: rgba(255,255,255,.9);
    color: #0b1320;
    border-radius: 999px;
    padding: .25rem .55rem;
    font-size: .8rem;
    font-weight: 600;
    display: flex;
    align-items: center;
    gap: .35rem
}

    .flip-hint i {
        font-size: 1rem
    }

/* Hàng nút Hiện thêm / Thu gọn ở đáy section */
.section-actions {
    display: flex;
    justify-content: center;
    gap: .5rem;
    margin-top: 14px
}

    </style>

</head>

<body>
    <!-- ==== Header ==== -->
    @Html.Partial("_HeaderPartial")

    <!-- ==== Offcanvas Giỏ hàng ==== -->
    @{
        var cart = Session["CART"] as List<WebQuanLiCuaHangTapHoa.Models.CartItem> ?? new List<WebQuanLiCuaHangTapHoa.Models.CartItem>();
    }
    <div id="cartPartial">
        @Html.Partial("_CartOffcanvasPartial", cart)
    </div>

    <!-- ==== Modal Đăng nhập/Đăng ký ==== -->
    @Html.Partial("_AuthModalPartial")

    <!-- ==== Nội dung trang ==== -->
    <main role="main">
        @RenderBody()
    </main>

    <!-- ==== Footer ==== -->
    @Html.Partial("_FooterPartial")

    <!-- ==== Nút Back to Top ==== -->
    <div class="backtop" id="backTop"><i class="bi bi-arrow-up"></i></div>

    <!-- ===== JS ===== -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>
    <script src='@Url.Content("~/Scripts/ThanhNhan/Layout.js")?v=@DateTime.UtcNow.Ticks'></script>

    @RenderSection("scripts", required: false)

    <script>
        /* ================== GIỎ HÀNG THẬT ================== */
        async function updateCartBadge() {
            try {
                const res = await fetch('@Url.Action("DemSoLuong", "GioHang")');
                const data = await res.json();
                const badge = document.getElementById('cartCount');
                if (badge) badge.innerText = data.tong || 0;
            } catch (e) {
                console.warn('Không thể cập nhật giỏ hàng:', e);
            }
        }

        async function reloadCartOffcanvas() {
            try {
                const html = await fetch('@Url.Action("PartialCart", "GioHang")').then(r => r.text());
                document.getElementById('cartPartial').innerHTML = html;
            } catch (e) {
                console.warn('Không thể nạp lại giỏ hàng:', e);
            }
        }

        async function addToCartReal(maSP) {
            try {
                const res = await fetch('@Url.Action("Them", "GioHang")?maSP=' + maSP, {
                    method: 'GET',
                    headers: { "X-Requested-With": "XMLHttpRequest" }
                });

                if (res.ok) {
                    const data = await res.json();
                    await updateCartBadge();
                    await reloadCartOffcanvas();

                    // Thông báo nhỏ góc phải
                    const toast = document.createElement('div');
                    toast.className = 'toast align-items-center text-bg-success border-0 position-fixed bottom-0 end-0 m-3 show';
                    toast.innerHTML = `
                        <div class="d-flex">
                            <div class="toast-body">
                                ✅ Đã thêm sản phẩm vào giỏ hàng!
                            </div>
                            <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
                        </div>`;
                    document.body.appendChild(toast);
                    setTimeout(() => toast.remove(), 2500);
                }
            } catch (err) {
                alert('Không thể thêm sản phẩm vào giỏ.');
                console.error(err);
            }
        }

        /* ================== SLIDERS ================== */
        const promoSwiper = new Swiper('#promoSwiper', {
            loop: true, speed: 600,
            autoplay: { delay: 3500, disableOnInteraction: false },
            spaceBetween: 24, slidesPerView: 1,
            breakpoints: { 768: { slidesPerView: 2 }, 1200: { slidesPerView: 3 } },
            navigation: { nextEl: '#promoNext', prevEl: '#promoPrev' }
        });

        const testi = new Swiper('#testiSwiper', {
            loop: true, speed: 580,
            autoplay: { delay: 3200, disableOnInteraction: false },
            spaceBetween: 24, slidesPerView: 1,
            breakpoints: { 768: { slidesPerView: 2 }, 1200: { slidesPerView: 3 } },
            navigation: { nextEl: '#testiNext', prevEl: '#testiPrev' }
        });

        const topSwiper = new Swiper('#topCarousel', {
            loop: true, speed: 600,
            autoplay: { delay: 3000, disableOnInteraction: false },
            slidesPerView: 1.25, centeredSlides: true, spaceBetween: 22,
            breakpoints: { 768: { slidesPerView: 1.6, spaceBetween: 24 }, 1200: { slidesPerView: 2.2, spaceBetween: 28 } },
            pagination: { el: '.swiper-pagination', clickable: true }
        });

        /* ================== NAVBAR THU GỌN ================== */
        const header = document.getElementById('appHeader');
        let lastY = window.scrollY;
        let scrollTimer = null;
        window.addEventListener('scroll', () => {
            const y = window.scrollY;
            const goingDown = y > lastY;
            if (goingDown && y > 120) { header.classList.add('nav-hidden') }
            else { header.classList.remove('nav-hidden'); header.classList.add('nav-compact') }
            lastY = y;
            clearTimeout(scrollTimer);
            scrollTimer = setTimeout(() => { header.classList.remove('nav-hidden'); header.classList.add('nav-compact') }, 300);
        });
        header.addEventListener('mouseenter', () => { header.classList.remove('nav-hidden'); header.classList.remove('nav-compact') });
        header.addEventListener('mouseleave', () => { if (window.scrollY > 120) header.classList.add('nav-compact') });

        /* ================== BACK-TO-TOP ================== */
        const backTop = document.getElementById('backTop');
        window.addEventListener('scroll', () => { backTop.style.display = window.scrollY > 400 ? 'flex' : 'none' });
        backTop.addEventListener('click', () => { window.scrollTo({ top: 0, behavior: 'smooth' }) });

        /* ================== KHỞI TẠO ================== */
        document.addEventListener('DOMContentLoaded', () => {
            updateCartBadge();
        });
    </script>
</body>
</html>
