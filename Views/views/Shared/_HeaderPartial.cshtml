@{
    dynamic kh = Session["KH"];
}

<header id="appHeader" class="tn-header shadow-sm bg-white">
    <div class="tn-container d-flex align-items-center justify-content-between">
        <!-- ===== NHÓM TRÁI ===== -->
        <div class="hd-left d-flex align-items-center gap-3 flex-wrap">
            <!-- Logo -->
            <a class="navbar-brand fw-bold d-flex align-items-center text-success"
               href="@Url.Action("Index","Home")" style="font-size:1.28rem;">
                <i class="bi bi-shop me-2" style="font-size:1.6rem;"></i>Thanh Nhan
            </a>

            <!-- Danh mục -->
            <div class="dropdown">
                <button class="btn btn-success dropdown-toggle d-flex align-items-center px-3 py-2"
                        type="button" data-bs-toggle="dropdown">
                    <i class="bi bi-list me-2" style="font-size:1.3rem;"></i><span>Danh mục</span>
                </button>
                <div class="dropdown-menu p-3 border-0 shadow-sm tn-cat-menu">
                    <div class="tn-cat-grid">@Html.Action("Menu", "DanhMuc")</div>
                </div>
            </div>

            <!-- Menu chính -->
            <nav class="tn-main d-flex align-items-center gap-3 flex-wrap">
                <a class="tn-link" href="@Url.Action("Index","Home")">Trang chủ</a>
                <a class="tn-link" href="#top-products">Top</a>
                <a class="tn-link" href="#featured">Mới</a>
                <a class="tn-link" href="#knowledge">Tin tức</a>
                <a class="tn-link" href="#">Giới thiệu</a>
                <a class="tn-link" href="#">Liên hệ</a>
                <a class="tn-link text-danger fw-semibold" href="#">
                    <i class="bi bi-percent me-1"></i>Giảm giá
                </a>
            </nav>
        </div>

        <!-- ===== NHÓM PHẢI ===== -->
        <div class="hd-right d-flex align-items-center gap-3">
            <!-- Thanh tìm kiếm dài hơn -->
            <form class="d-flex align-items-center"
                  method="get" action="@Url.Action("Index","Home")"
                  style="max-width:680px; flex:1;">
                <input class="form-control tn-search" name="kw" value="@ViewBag.Keyword"
                       type="search" placeholder="Tìm sản phẩm..." />
                <button class="btn btn-success ms-2 tn-btn-search" type="submit">
                    <i class="bi bi-search"></i>
                </button>
            </form>

            <!-- Tài khoản -->
            @if (kh == null)
            {
                <a class="btn-icon" href="@Url.Action("DangNhap","TaiKhoan")" aria-label="Đăng nhập">
                    <i class="bi bi-person-circle"></i>
                </a>
            }
            else
            {
                <div class="dropdown">
                    <button class="btn-icon dropdown-toggle" type="button" data-bs-toggle="dropdown">
                        <i class="bi bi-person-circle"></i>
                    </button>
                    <ul class="dropdown-menu dropdown-menu-end shadow-sm">
                        <li>
                            <a class="dropdown-item" href="@Url.Action("ThongTin","TaiKhoan")">
                                <i class="bi bi-person-lines-fill me-2"></i>Thông tin
                            </a>
                        </li>
                        <li><hr class="dropdown-divider" /></li>
                        <li>
                            <a class="dropdown-item text-danger" href="@Url.Action("DangXuat","TaiKhoan")">
                                <i class="bi bi-box-arrow-right me-2"></i>Đăng xuất
                            </a>
                        </li>
                    </ul>
                </div>
            }

            <!-- Giỏ hàng -->
            <button class="btn-icon btn-icon-outline position-relative"
                    data-bs-toggle="offcanvas"
                    data-bs-target="#cartOffcanvas"
                    aria-controls="cartOffcanvas">
                <i class="bi bi-bag" style="font-size: 1.6rem;"></i>
                <span class="badge-pos badge rounded-pill bg-danger" id="cartCount">0</span>
            </button>


        </div>
    </div>

    
</header>
