<div id="search-result-container">
    @Html.Partial("_SearchResult", (IEnumerable<WebQuanLiCuaHangTapHoa.Models.SanPhamView>)ViewBag.SearchResult)
</div>



<!-- ======================= FLASH SALE (DỮ LIỆU real===================== -->
<section id="flash-sale">
    <div class="container">
        <div class="d-flex justify-content-between align-items-center mb-4">
