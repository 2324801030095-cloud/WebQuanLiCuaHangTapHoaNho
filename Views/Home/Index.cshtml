<script>
    document.addEventListener('DOMContentLoaded', function () {
        // 1. Promo Slider
        new Swiper('#promoSwiper', {
            slidesPerView: 1,
            spaceBetween: 20,
            loop: true,
            breakpoints: {
                768: { slidesPerView: 2 },
                1024: { slidesPerView: 3 }
            },
            navigation: {
                nextEl: '#promoNext',
                prevEl: '#promoPrev',
            },
        });

        // 2. Top Product Carousel (AUTO LOOP MƯỢT MÀ)
        new Swiper('#topCarousel', {
            effect: 'coverflow', // Giữ hiệu ứng 3D
            grabCursor: true,
            centeredSlides: true,
            slidesPerView: 'auto', // Tự động tính toán số lượng slide
            loop: true,           // BẬT VÒNG LẶP VÔ HẠN
            speed: 800,           // Tốc độ chuyển cảnh mượt hơn (800ms)
            autoplay: {
                delay: 2000,      // Tự chạy sau 2 giây
                disableOnInteraction: false, // Vẫn chạy tiếp khi chạm vào
            },
            coverflowEffect: {
                rotate: 50,
                stretch: 0,
                depth: 100,
                modifier: 1,
                slideShadows: true,
            },
            pagination: {
                el: '.swiper-pagination',
                clickable: true
            },
            // initialSlide: 1 // Không cần thiết khi đã loop
        });

        // 3. Testimonial Slider
        new Swiper('#testiSwiper', {
            slidesPerView: 1,
            spaceBetween: 30,
            loop: true,
            autoplay: {
                delay: 5000,
                disableOnInteraction: false,
            },
            breakpoints: {
                768: { slidesPerView: 2 },
                1024: { slidesPerView: 3 }
            },
            pagination: {
                el: '.swiper-pagination',
                clickable: true
            }
        });
    });
</script>