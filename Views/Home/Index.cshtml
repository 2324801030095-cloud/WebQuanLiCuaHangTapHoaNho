                Xem thêm đánh giá <i class="bi bi-arrow-right ms-1"></i>
            </a>
        </div>

    </div>
</section>





<section id="newsletter" class="py-5 footer-classic">
    <div class="container">
        <div class="row align-items-center g-4">
            <div class="col-lg-3 text-center d-none d-lg-block">
                <img src="https://cdn-icons-png.flaticon.com/512/2921/2921822.png"
                     alt="Mailbox" class="img-fluid" style="max-width: 150px; filter: drop-shadow(0 0 10px rgba(255,255,255,0.2));">
            </div>
            <div class="col-lg-9">
                <h2 class="fw-bold mb-2">Đăng ký nhận tin</h2>
                <p class="mb-4 opacity-75">Nhận ngay mã giảm giá 10% cho đơn hàng đầu tiên & thông tin khuyến mãi hàng tuần.</p>

                <form class="d-flex gap-2 flex-column flex-sm-row" style="max-width: 600px;">
                    <input type="email" class="form-control form-control-lg border-0 rounded-pill px-4"
                           placeholder="Nhập địa chỉ email của bạn..." required>
                    <button class="btn btn-warning btn-lg rounded-pill px-4 fw-bold text-dark" type="submit">Đăng ký ngay</button>
                </form>
            </div>
        </div>
    </div>
</section>

<script>
    document.addEventListener("DOMContentLoaded", function () {

        /* ================================
           1) PROMO SLIDER
           ================================ */
        new Swiper('#promoSwiper', {
            slidesPerView: 1,
            spaceBetween: 20,
            loop: true,
            breakpoints: {
                768: { slidesPerView: 2 },
                1024: { slidesPerView: 3 }
            },
            navigation: {
                nextEl: '#promoNext',
                prevEl: '#promoPrev',
            },
        });


        /* ================================
           2) TOP TODAY – 3D FLIP (Swiper)
           ================================ */
        new Swiper('#topCarousel', {
            effect: 'coverflow',
            grabCursor: true,
            centeredSlides: true,
            slidesPerView: 'auto',
            loop: true,
            speed: 800,
            autoplay: {
                delay: 2000,
                disableOnInteraction: false,
            },
            coverflowEffect: {
                rotate: 50,
                stretch: 0,
                depth: 100,
                modifier: 1,
                slideShadows: true,
            },
            pagination: {
                el: '.swiper-pagination',
                clickable: true
            }
        });


        /* ================================
           3) TESTIMONIAL SLIDER
           ================================ */
        new Swiper('#testiSwiper', {
            slidesPerView: 1,
            spaceBetween: 30,
            loop: true,
            autoplay: {
                delay: 5000,
                disableOnInteraction: false,
            },
            breakpoints: {
                768: { slidesPerView: 2 },
                1024: { slidesPerView: 3 }
            },
            pagination: {
                el: '.swiper-pagination',
                clickable: true
            }
        });


        /* ======================================================
            4) HIỆN THÊM / THU GỌN - TOP SELLING
           ====================================================== */
        let tsShow = 8;
        const tsCards = Array.from(document.querySelectorAll(
            '#topSellingWrap .col-12.col-sm-6.col-md-4.col-lg-3'
        ));

        function renderTopSelling() {
            tsCards.forEach((el, i) => {
                el.style.display = (i < tsShow) ? "" : "none";
            });

            document.getElementById("tsMore").classList.toggle("d-none", tsShow >= tsCards.length);
            document.getElementById("tsLess").classList.toggle("d-none", tsShow <= 8);
        }

        renderTopSelling();

        document.getElementById("tsMore").addEventListener("click", () => {
            tsShow = Math.min(tsShow + 8, tsCards.length);
            renderTopSelling();
        });

        document.getElementById("tsLess").addEventListener("click", () => {
            tsShow = 8;
            renderTopSelling();
            document.getElementById("topSellingWrap").scrollIntoView({ behavior: "smooth" });
        });


        /* ======================================================
            5) HIỆN THÊM / THU GỌN - NEW PRODUCTS
           ====================================================== */
        let npShow = 8;
        const npCards = Array.from(document.querySelectorAll(
            '#newProWrap .col-12.col-sm-6.col-md-4.col-lg-3'
        ));

        function renderNewProducts() {
            npCards.forEach((el, i) => {
                el.style.display = (i < npShow) ? "" : "none";
            });

            document.getElementById("npMore").classList.toggle("d-none", npShow >= npCards.length);
            document.getElementById("npLess").classList.toggle("d-none", npShow <= 8);
        }

        renderNewProducts();

        document.getElementById("npMore").addEventListener("click", () => {
            npShow = Math.min(npShow + 8, npCards.length);
            renderNewProducts();
        });

        document.getElementById("npLess").addEventListener("click", () => {
            npShow = 8;
            renderNewProducts();
            document.getElementById("newProWrap").scrollIntoView({ behavior: "smooth" });
        });

    });
</script>

