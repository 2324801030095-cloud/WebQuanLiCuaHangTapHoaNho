@model WebQuanLiCuaHangTapHoa.Models.KhachHang
@{
    ViewBag.Title = "Thông tin tài khoản";
    Layout = "~/Views/Shared/_LayoutUser.cshtml";
}

<div class="container py-5">
    <div class="card shadow-sm border-0">
        <div class="card-body p-4">
            <h3 class="text-success mb-4">
                <i class="bi bi-person-lines-fill me-2"></i> Thông tin tài khoản
            </h3>

            <dl class="row mb-0">
                <dt class="col-sm-3">Họ tên</dt>
                <dd class="col-sm-9">@Model.TenKH</dd>

                <dt class="col-sm-3">Số điện thoại</dt>
                <dd class="col-sm-9">@Model.SoDT</dd>

                <dt class="col-sm-3">Địa chỉ</dt>
                <dd class="col-sm-9">@Model.DiaChi</dd>

                <dt class="col-sm-3">Email</dt>
                <dd class="col-sm-9">@ViewBag.Email</dd>
            </dl>

            <div class="mt-4">
                <a href="@Url.Action("Index", "Home")" class="btn btn-secondary">
                    <i class="bi bi-house-door me-2"></i> Về trang chủ
                </a>
                <a href="@Url.Action("DangXuat", "TaiKhoan")" class="btn btn-danger ms-2">
                    <i class="bi bi-box-arrow-right me-2"></i> Đăng xuất
                </a>
            </div>
        </div>
    </div>
</div>
