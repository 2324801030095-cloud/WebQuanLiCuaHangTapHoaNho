@using WebQuanLiCuaHangTapHoa.Helpers
@model IEnumerable<WebQuanLiCuaHangTapHoa.Models.DanhMuc>

@if (Model == null || !Model.Any())
{
    <span class="text-muted small">Chưa có danh mục</span>
}
else
{
    <div class="tn-cat-grid">
        @foreach (var dm in Model)
        {
            // Lấy icon và tên hiển thị từ helper
            var (displayName, icon) = CategoryIconHelper.GetCategoryInfo(dm.TenDM);

            <a class="dropdown-item d-flex align-items-center"
               href="@Url.Action("DanhSach", "DanhMuc", new { maDM = dm.MaDM })"
               title="@dm.MoTa">

                <i class="bi @icon me-2 text-success"></i>
                <span>@displayName</span>

            </a>
        }
    </div>
}
