@model IEnumerable<WebQuanLiCuaHangTapHoa.Models.DanhMuc>

@{
    // Bản đồ tên không dấu -> có dấu (tạm thời để hiển thị)
    var mapTenCoDau = new Dictionary<string, string>
    {
        ["BanhKeo"] = "Bánh kẹo",
        ["BoVaTrung"] = "Bơ & Trứng",
        ["DoUong"] = "Đồ uống",
        ["GaoVaNguCoc"] = "Gạo & Ngũ cốc",
        ["GiaViVaDauAn"] = "Gia vị & Dầu ăn",
        ["HoaPhamGiaDung"] = "Hóa phẩm gia dụng",
        ["RauCuQua"] = "Rau củ quả",
        ["SuaCacLoai"] = "Sữa các loại"
    };
}

@if (Model == null || !Model.Any())
{
    <span class="text-muted small">Chưa có danh mục</span>
}
else
{
    <ul class="list-unstyled">
        @foreach (var dm in Model)
        {
            var tenHienThi = mapTenCoDau.ContainsKey(dm.TenDM) ? mapTenCoDau[dm.TenDM] : dm.TenDM;

            <li>
                <a class="dropdown-item d-flex align-items-center"
                   href="@Url.Action("TatCa", "DanhMuc")"
                   title="@dm.MoTa">
                    <i class="bi bi-tag text-success me-2"></i>
                    <span>@tenHienThi</span>
                </a>
            </li>
        }
    </ul>
}
