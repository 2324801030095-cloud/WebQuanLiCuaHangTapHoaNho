@using WebQuanLiCuaHangTapHoa.Models.ViewModels
@using WebQuanLiCuaHangTapHoa.Helpers
@model IEnumerable<WebQuanLiCuaHangTapHoa.Models.SanPhamView>

@{
    Layout = "~/Views/Shared/_LayoutUser.cshtml";
    var tenDM = ViewBag.TenDM as string ?? "Sản phẩm";

    Func<string, string> imgByFile = file =>
    {
        return string.IsNullOrWhiteSpace(file)
            ? Url.Content("~/Content/Images/no-image.png")
            : Url.Content("~/Content/Images/" + file.Trim());
    };

    var cats = ViewBag.Cats as IEnumerable<CatItemVM> ?? Enumerable.Empty<CatItemVM>();
    int sel = ViewBag.Selected ?? 0;
}

<section class="py-4">
    <div class="container">
        <div class="row g-4 catalog-layout">

            <!-- =========== SIDEBAR DANH MỤC =========== -->
            <aside class="col-12 col-lg-3">
                <div class="cat-box">

                    <div class="cat-header">
                        <strong class="cat-title">Sản Phẩm</strong>

                        <!-- ⭐ FIX #1: XÓA LỌC -->
                        <a href="@Url.Action("TatCa","DanhMuc")"
                           class="btn btn-sm btn-outline-secondary cat-clear">
                            Xóa lọc
                        </a>
                    </div>

                    @foreach (var c in cats)
                    {
                        var active = (sel == c.MaDM) ? "active" : "";
                        var icon = CategoryIconHelper.GetIcon(c.TenDM);
                        var displayName = CategoryIconHelper.GetDisplayName(c.TenDM);
                        
                        <a class="cat-item d-flex align-items-center justify-content-between @active"
                           href="@Url.Action("DanhSach","DanhMuc", new { maDM = c.MaDM })">
                            <span class="d-flex align-items-center gap-2">
                                <i class="bi @icon"></i> <span>@displayName</span>
                            </span>
                            <span class="cat-count">@c.Count</span>
                        </a>
                    }

                    <div class="p-3 border-top">
                        <div class="form-check mb-2">
                            <input class="form-check-input" type="checkbox" id="ckDiscount">
                            <label class="form-check-label" for="ckDiscount">
                                Đang giảm giá
                            </label>
                        </div>

                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" id="ckInStock" checked>
                            <label class="form-check-label" for="ckInStock">
                                Còn hàng
                            </label>
                        </div>
                    </div>

                </div>
            </aside>

            <!-- =========== MAIN CONTENT =========== -->
            <main class="col-12 col-lg-9">

                <div class="toolbar d-flex align-items-center justify-content-between mb-3">
                    <div class="small text-muted" id="resultText">
                        Hiển thị @Model.Count() / @Model.Count() kết quả
                    </div>

                    <div class="d-flex align-items-center gap-2">
                        <input id="kw" class="form-control form-control-sm" style="width:220px"
                               placeholder="Tìm theo tên..." />

                        <select id="sort" class="form-select form-select-sm" style="width:200px">
                            <option value="default">Thứ tự mặc định</option>
                            <option value="priceAsc">Giá tăng dần</option>
                            <option value="priceDesc">Giá giảm dần</option>
                            <option value="nameAsc">Tên A→Z</option>
                            <option value="nameDesc">Tên Z→A</option>
                        </select>

                        <button id="btnApply" class="btn btn-sm btn-brand">
                            <i class="bi bi-sliders me-1"></i> Áp dụng
                        </button>
                    </div>
                </div>

                <!-- =========== GRID SẢN PHẨM =========== -->
                <div id="grid" class="row g-4">

                    @foreach (var p in Model)
                    {
                        <div class="col-12 col-md-6 col-lg-3">
                            <div class="card h-100 shadow-sm border-0">

                                <img class="card-img-top"
                                     src="@imgByFile(p.HinhAnh)"
                                     alt="@p.TenSP" />

                                <div class="card-body d-flex flex-column">

                                    <h6 class="fw-semibold mb-2 text-truncate" title="@p.TenSP">
                                        @p.TenSP
                                    </h6>

                                    <div class="mb-2">
                                        <span class="text-success fw-bold">
                                            @String.Format("{0:N0} ₫", p.GiaBan)
                                        </span>
                                    </div>

                                    @{
                                        var pct = (p.Ton <= 0) ? 2 : (p.Ton > 100 ? 100 : p.Ton);
                                    }

                                    <div class="stock-wrap mb-3">
                                        <div class="stock-bar">
                                            <span style="width:@pct"></span>
                                        </div>
                                        <small class="text-muted mt-1 d-inline-block">
                                            Tồn: @p.Ton
                                        </small>
                                    </div>

                                    <div class="mt-auto d-flex gap-2">

                                        <a class="btn btn-outline-success btn-sm flex-fill"
                                           href="@Url.Action("ChiTiet","SanPham", new { id = p.MaSP })">
                                            <i class="bi bi-eye me-1"></i> Xem
                                        </a>

                                        <!-- ⭐ FIX #4: NÚT THÊM — CHUẨN HÓA btn-addcart -->
                                        <button type="button"
                                                class="btn btn-brand btn-sm flex-fill btn-addcart"
                                                data-id="@p.MaSP"
                                                data-img="@imgByFile(p.HinhAnh)"
                                                data-name="@p.TenSP"
                                                data-price="@p.GiaBan">
                                            <i class="bi bi-bag-plus me-1"></i> Thêm
                                        </button>


                                    </div>

                                </div>
                            </div>
                        </div>
                    }
                </div>

                <div class="d-flex justify-content-center gap-2 mt-3">
                    <button id="btnMore" class="btn btn-outline-success btn-sm">
                        <i class="bi bi-chevron-double-right me-1"></i> Hiện thêm
                    </button>

                    <button id="btnLess" class="btn btn-outline-secondary btn-sm">
                        <i class="bi bi-chevron-double-left me-1"></i> Thu gọn
                    </button>
                </div>

            </main>
        </div>
    </div>
</section>

@section scripts {
    <script>
        (function () {

            const grid = document.getElementById("grid");

            // ⭐ FIX QUAN TRỌNG – LẤY ĐÚNG CÁC THẺ .col chứa sản phẩm
            let cards = Array.from(grid.querySelectorAll(".col-12"));

            function updateResult() {
                const visible = cards.filter(el => el.style.display !== "none").length;
                document.getElementById("resultText").textContent =
                    `Hiển thị ${visible} / ${cards.length} kết quả`;
            }

            function applyFilters() {

                const kw = document.getElementById("kw").value.toLowerCase().trim();
                const sort = document.getElementById("sort").value;

                const ckDiscount = document.getElementById("ckDiscount").checked;
                const ckInStock = document.getElementById("ckInStock").checked;

                cards.forEach(card => {

                    const name = card.querySelector("h6").textContent.toLowerCase();
                    const price = parseFloat(card.querySelector(".text-success").textContent.replace(/[^\d]/g, ''));
                    const ton = parseInt(card.querySelector(".stock-wrap small").textContent.replace(/[^\d]/g, '-'));

                    let visible = true;

                    if (kw && !name.includes(kw))
                        visible = false;

                    if (ckInStock && ton <= 0)
                        visible = false;

                    // ⭐ FIX GIẢM GIÁ – KHÔNG LÀM HỎNG GIAO DIỆN
                    if (ckDiscount) {
                        const el = card.querySelector("[data-discount='1']");
                        if (!el)
                            visible = false;
                    }

                    card.style.display = visible ? "" : "none";
                });

                let visibleCards = cards.filter(c => c.style.display !== "none");

                visibleCards.sort((a, b) => {

                    const nameA = a.querySelector("h6").textContent.trim().toLowerCase();
                    const nameB = b.querySelector("h6").textContent.trim().toLowerCase();

                    const priceA = parseFloat(a.querySelector(".text-success").textContent.replace(/[^\d]/g, ''));
                    const priceB = parseFloat(b.querySelector(".text-success").textContent.replace(/[^\d]/g, ''));

                    switch (sort) {
                        case "priceAsc": return priceA - priceB;
                        case "priceDesc": return priceB - priceA;
                        case "nameAsc": return nameA.localeCompare(nameB);
                        case "nameDesc": return nameB.localeCompare(nameA);
                    }
                    return 0;
                });

                visibleCards.forEach(card => grid.appendChild(card));

                updateResult();
            }

            document.getElementById("btnApply").addEventListener("click", applyFilters);

            let show = 8;

            function applyShowLimit() {
                cards.forEach((el, idx) => {
                    el.style.display = idx < show ? "" : "none";
                });
                updateResult();
            }

            applyShowLimit();

            document.getElementById("btnMore").addEventListener("click", () => {
                show = Math.min(show + 8, cards.length);
                applyShowLimit();
            });

            document.getElementById("btnLess").addEventListener("click", () => {
                show = 8;
                applyShowLimit();
                grid.scrollIntoView({ behavior: "smooth" });
            });

        })();
    </script>
}



