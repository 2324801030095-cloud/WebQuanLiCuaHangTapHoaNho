@{
    ViewBag.Title = "Thanh toán MoMo";
    Layout = "~/Views/Shared/_LayoutUser.cshtml";
}

<style>
    /* ============================
       VÙNG CHUNG – TONE MOMO
       ============================ */
    .momo-wrapper {
        max-width: 780px;
        margin: 50px auto;
        padding: 40px 36px;
        border-radius: 22px;
        background: linear-gradient(145deg, #ffffff, #fff6fb);
        box-shadow: 0 25px 70px rgba(175, 0, 110, 0.20);
        border: 1px solid #f3d1e9;
        animation: fadeIn .5s ease-out;
    }

    @@keyframes fadeIn {
        from { opacity: 0; transform: translateY(20px); }
        to { opacity: 1; transform: translateY(0); }
    }

    /* ============================
       HEADER
       ============================ */
    .momo-header {
        text-align: center;
        margin-bottom: 28px;
    }

    .momo-title {
        font-size: 2.4rem;
        font-weight: 900;
        color: #b30078;
        text-transform: uppercase;
        margin-bottom: 12px;
        text-shadow: 0 4px 14px rgba(160, 0, 106, 0.25);
    }

    .momo-amount {
        font-size: 2.3rem;
        font-weight: 900;
        background: linear-gradient(90deg, #ff0099, #d00085);
        color: transparent;
        -webkit-background-clip: text;
        margin-bottom: 20px;
    }

    /* ============================
       QR CODE
       ============================ */
    .momo-qr {
        text-align: center;
        margin: 25px 0 35px;
    }

    .momo-qr img {
        max-width: 280px;
        border-radius: 14px;
        box-shadow: 0 20px 45px rgba(222, 0, 140, 0.35);
        animation: popIn .5s ease-out;
    }

    @@keyframes popIn {
        0% { opacity: 0; transform: scale(.7); }
        100% { opacity: 1; transform: scale(1); }
    }

    /* ============================
       NOTE
       ============================ */
    .momo-note {
        background: #ffe9f7;
        color: #a1006f;
        font-weight: 600;
        padding: 16px 20px;
        border-radius: 12px;
        border-left: 5px solid #d00085;
        text-align: center;
        margin-bottom: 32px;
        box-shadow: 0 4px 12px rgba(161, 0, 111, 0.1);
    }

    /* ============================
       INFO LIST
       ============================ */
    .momo-info .list-group-item {
        font-size: 1.1rem;
        font-weight: 600;
        border: none;
        background: #fff;
        padding: 14px 18px;
        border-bottom: 1px solid #f4c7e7;
    }

    .momo-info .list-group-item:last-child {
        border-bottom: none;
    }

    /* ============================
       BUTTON
       ============================ */
    .btn-back {
        padding: 14px 35px;
        font-size: 1.1rem;
        font-weight: 700;
        border-radius: 14px;
        background: linear-gradient(135deg, #d00085, #a1006f);
        border: none;
        color: #fff;
        transition: .25s;
        display: block;
        margin: 0 auto;
        box-shadow: 0 12px 28px rgba(208, 0, 133, 0.35);
    }

    .btn-back:hover {
        background: linear-gradient(135deg, #b0006f, #7a0055);
        transform: translateY(-3px);
        box-shadow: 0 18px 40px rgba(160, 0, 106, 0.45);
    }
</style>

<div class="momo-wrapper">

    <div class="momo-header">
        <div class="momo-title">Thanh Toán MoMo</div>
        <div class="momo-amount">@ViewBag.Amount</div>
    </div>

    <div class="momo-qr">
        <img src="@ViewBag.QRImage" alt="QR MoMo" />
    </div>

    <div class="momo-note">
        Quét mã bằng ứng dụng <strong>MoMo</strong> hoặc ngân hàng để hoàn tất thanh toán.
    </div>

    <ul class="list-group momo-info">
        <li class="list-group-item"><strong>Chủ tài khoản:</strong> Nguyễn Quang Long</li>
        <li class="list-group-item"><strong>Số MoMo:</strong> @ViewBag.STK</li>
        <li class="list-group-item"><strong>Nội dung:</strong> @ViewBag.OrderInfo</li>
    </ul>

    <a href="/GioHang/GioHang" class="btn-back">Quay về giỏ hàng</a>
</div>
