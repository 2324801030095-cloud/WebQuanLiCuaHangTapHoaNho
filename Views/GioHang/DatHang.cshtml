@{
    ViewBag.Title = "Đặt hàng thành công";
    Layout = "~/Views/Shared/_LayoutUser.cshtml";
}

<section class="py-5 text-center">
    <div class="container">
        <div class="alert alert-success shadow-lg p-4 rounded-3">
            <h2 class="fw-bold text-success mb-3"><i class="bi bi-check2-circle"></i> Đặt hàng thành công!</h2>
            <p class="lead">
                Cảm ơn bạn đã đặt hàng tại <strong>Cửa hàng Tạp hóa Thanh Nhàn</strong> 🎉
            </p>
            <p>Mã đơn hàng của bạn là: <strong>#@ViewBag.MaHD</strong></p>
            <a href="@Url.Action("Index", "Home")" class="btn btn-outline-success mt-3">
                <i class="bi bi-house"></i> Quay lại trang chủ
            </a>
        </div>
    </div>
</section>
