@model IEnumerable<WebQuanLiCuaHangTapHoa.Models.ViewModels.Testimonial>

@{
    ViewBag.Title = "Tất cả đánh giá khách hàng";
}

<style>
    .rating i {
        color: #fbbf24;
        font-size: 1.2rem;
    }

    .review-card {
        border-radius: 14px;
        padding: 20px;
        background: #fff;
        box-shadow: 0 6px 18px rgba(0,0,0,0.06);
        margin-bottom: 20px;
        border: 1px solid #e5e7eb;
        transition: .25s;
    }

        .review-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 10px 25px rgba(0,0,0,0.10);
        }

    .review-name {
        font-weight: 700;
        font-size: 1.1rem;
        color: #14532d;
    }

    .review-date {
        font-size: .9rem;
        color: #6b7280;
    }

    /* ===== NÚT CHI TIẾT ĐẸP ===== */
    .btn-review-detail-modern {
        background: linear-gradient(135deg, #0ea5e9, #06b6d4);
        color: white;
        border: none;
        padding: 0.65rem 1.25rem;
        font-size: 0.95rem;
        font-weight: 600;
        border-radius: 8px;
        transition: all 0.3s ease;
        box-shadow: 0 4px 12px rgba(6, 182, 212, 0.35);
        display: inline-flex;
        align-items: center;
        gap: 6px;
        cursor: pointer;
        white-space: nowrap;
    }

        .btn-review-detail-modern:hover {
            background: linear-gradient(135deg, #06b6d4, #0891b2);
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(6, 182, 212, 0.5);
            color: white;
            text-decoration: none;
        }

        .btn-review-detail-modern:active {
            transform: translateY(0);
        }
</style>

<div class="container py-5">

    <!-- NÚT QUAY LẠI -->
    <div class="mb-4">
        <a href="@Url.Action("Index","Home")#testimonials"
           class="btn btn-outline-success px-4 rounded-pill">
            ← Quay về trang chủ
        </a>
    </div>

    <h2 class="fw-bold mb-4 text-center" style="color:#0a4b2f;">
        Tất cả đánh giá khách hàng
    </h2>

    @if (!Model.Any())
    {
        <div class="alert alert-info rounded-4">
            Chưa có đánh giá nào được duyệt.
        </div>
    }
    else
    {
        <div id="reviewList">
            @foreach (var r in Model)
            {
                <div class="review-card review-item">
                    <div class="d-flex justify-content-between align-items-start mb-2">
                        <div>
                            <div class="review-name">@r.TenKH</div>
                            <div class="review-date">
                                @r.NgayDanhGia.ToString("dd/MM/yyyy HH:mm")
                            </div>
                        </div>
                        <!-- ✅ NÚT CHI TIẾT MỚI ĐẸP -->
                        <button type="button"
                                class="btn btn-review-detail-modern"
                                title="Xem chi tiết đánh giá + lịch sử mua hàng"
                                onclick="xemChiTietDG(@r.MaDG)">
                            <i class="fa-solid fa-magnifying-glass me-1"></i>
                            Chi tiết
                        </button>
                    </div>

                    <div class="rating mb-2">
                        @for (int i = 1; i <= 5; i++)
                        {
                            if (i <= r.Diem)
                            {
                                <i class="bi bi-star-fill"></i>
                            }
                            else
                            {
                                <i class="bi bi-star"></i>
                            }
                        }
                    </div>

                    <p class="text-muted" style="white-space:pre-line;">
                        @r.NoiDung
                    </p>

                    <div class="mt-3 d-flex justify-content-between align-items-center">
                        @if (r.MaSP.HasValue)
                        {
                            <a href="@Url.Action("ChiTiet", "SanPham", new { id = r.MaSP })"
                               class="btn btn-outline-success btn-sm rounded-pill px-3">
                                <i class="bi bi-box-seam me-1"></i>Xem sản phẩm
                            </a>
                        }
                        else
                        {
                            <span class="text-muted small">
                                <i class="bi bi-shop me-1"></i>Đánh giá cửa hàng
                            </span>
                        }
                        <span class="text-muted small">
                            <i class="bi bi-clock me-1"></i>@r.NgayDanhGia.ToString("dd/MM/yyyy HH:mm")
                        </span>
                    </div>
                </div>
            }
        </div>

        <!-- NÚT HIỆN THÊM / THU GỌN -->
        <div class="text-center mt-4">
            <button id="rvMore" class="btn btn-outline-success px-4 rounded-pill">
                <i class="bi bi-chevron-double-down me-1"></i> Hiện thêm
            </button>

            <button id="rvLess" class="btn btn-outline-secondary px-4 rounded-pill d-none">
                <i class="bi bi-chevron-double-up me-1"></i> Thu gọn
            </button>
        </div>
    }
</div>

<!-- ✅ MODAL CONTAINER -->
<div id="modalContainer"></div>

<script>
    document.addEventListener("DOMContentLoaded", function () {

        /* ==========================
           HIỆN THÊM / THU GỌN
           ========================== */
        let rvInitial = 5;
        let rvShow = rvInitial;

        const rvCards = Array.from(document.querySelectorAll(".review-item"));
        const btnMore = document.getElementById("rvMore");
        const btnLess = document.getElementById("rvLess");
        const reviewList = document.getElementById("reviewList");

        function renderReviews() {
            if (!rvCards || rvCards.length === 0) {
                if (btnMore) btnMore.classList.add("d-none");
                if (btnLess) btnLess.classList.add("d-none");
                return;
            }

            rvCards.forEach((el, i) => {
                el.style.display = (i < rvShow) ? "" : "none";
            });

            if (btnMore) btnMore.classList.toggle("d-none", rvShow >= rvCards.length);
            if (btnLess) btnLess.classList.toggle("d-none", rvShow <= rvInitial);
        }

        renderReviews();

        if (btnMore) {
            btnMore.addEventListener("click", () => {
                rvShow = Math.min(rvShow + rvInitial, rvCards.length);
                renderReviews();
                if (reviewList) reviewList.scrollIntoView({ behavior: "smooth", block: "start" });
            });
        }

        if (btnLess) {
            btnLess.addEventListener("click", () => {
                rvShow = rvInitial;
                renderReviews();
                if (reviewList) reviewList.scrollIntoView({ behavior: "smooth", block: "start" });
            });
        }
    });

    // ✅ XEM CHI TIẾT ĐÁNH GIÁ
    function xemChiTietDG(id) {
        fetch(`/DanhGia/ChiTiet/${id}`)
            .then(res => res.text())
            .then(html => {
                document.getElementById("modalContainer").innerHTML = html;
                new bootstrap.Modal(document.getElementById("modalChiTietDG")).show();
            })
            .catch(err => {
                console.error(err);
                alert('Lỗi khi tải chi tiết đánh giá');
            });
    }
</script>