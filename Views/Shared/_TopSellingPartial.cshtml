@model IEnumerable<WebQuanLiCuaHangTapHoa.Models.SanPhamView>

@if (Model == null || !Model.Any())
{
    <div class="text-center text-muted py-5">
        <i class="bi bi-inbox" style="font-size:2rem;"></i>
        <div class="mt-2">Chưa có dữ liệu sản phẩm bán chạy.</div>
    </div>
}
else
{
    <div class="row g-4">
        @foreach (var sp in Model)
        {
            <div class="col-12 col-sm-6 col-md-4 col-lg-3">
                @Html.Partial("_ProductCardPartial", sp)
            </div>
        }
    </div>
}
