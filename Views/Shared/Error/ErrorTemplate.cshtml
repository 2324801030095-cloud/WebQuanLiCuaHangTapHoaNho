@{
    Layout = "~/Views/Shared/_ErrorLayout.cshtml";
    var status = ViewBag.StatusCode ?? Response.StatusCode;
    ViewBag.Title = "Lỗi " + status;
}

@section ErrorIcon{
    <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M12 2a10 10 0 100 20 10 10 0 000-20z" fill="#0f172a"/>
        <path d="M12 7v6" stroke="#f97316" stroke-width="1.6" stroke-linecap="round"/>
        <circle cx="12" cy="17" r="1" fill="#f97316"/>
    </svg>
}

@section ErrorBadge{Hệ thống}
@section ErrorCode{@status}
@section ErrorTitle{Đã có lỗi ngoài ý muốn}
@section ErrorMessage{Chúng tôi đang xử lý sự cố này. Vui lòng thử lại sau ít phút hoặc quay về trang chủ.}
@section ErrorActions{
    <a class="btn primary" href="@Url.Action("Index", "Home")">Về trang chủ</a>
    <a class="btn ghost" href="javascript:history.back()">Quay lại</a>
}
@section ErrorNote{Nếu vẫn gặp lỗi, vui lòng thử tải lại hoặc liên hệ bộ phận hỗ trợ.}
