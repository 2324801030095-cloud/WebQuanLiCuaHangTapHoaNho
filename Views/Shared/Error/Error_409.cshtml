@{
    Layout = "~/Views/Shared/_ErrorLayout.cshtml";
    ViewBag.Title = "Lỗi 409";
    ViewBag.StatusCode = 409;
}

@section ErrorIcon{
    <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M12 2a10 10 0 100 20 10 10 0 000-20z" fill="#0f172a"/>
        <path d="M12 7v6" stroke="#2f7cf6" stroke-width="1.6" stroke-linecap="round"/>
        <circle cx="12" cy="17" r="1" fill="#2f7cf6"/>
    </svg>
}

@section ErrorBadge{Conflict}
@section ErrorCode{409}
@section ErrorTitle{Xung đột dữ liệu}
@section ErrorMessage{Yêu cầu bị xung đột với trạng thái hiện tại. Vui lòng thử lại sau.}
@section ErrorActions{
    <a class="btn primary" href="@Url.Action("Index", "Home")">Về trang chủ</a>
    <a class="btn ghost" href="javascript:history.back()">Quay lại</a>
}
@section ErrorNote{Mã lỗi: 409 • Thời gian: @DateTime.Now.ToString("HH:mm dd/MM/yyyy")}
