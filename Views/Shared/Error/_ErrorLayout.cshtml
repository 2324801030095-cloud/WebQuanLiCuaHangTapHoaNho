@{
    Layout = null;
}
<!doctype html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>Error</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <style>
        body{background:#f8fafc;color:#0f172a}
        .err-card{max-width:760px;margin:80px auto}
        .err-ico{width:84px;height:84px;border-radius:50%;background:#fee2e2;display:flex;align-items:center;justify-content:center}
        .err-title{font-size:28px;font-weight:800}
        .err-note{opacity:.7}
        .btn-brand{background:#16a34a;color:#fff}
    </style>
</head>
<body>
    <div class="container err-card">
        <div class="card p-4">
            <div class="d-flex gap-3 align-items-center">
                <div class="err-ico">
                    @RenderSection("ErrorIcon", required: false)
                </div>
                <div>
                    <div class="err-title">@RenderSection("ErrorTitle", required: false)</div>
                    <div class="err-note">@RenderSection("ErrorNote", required: false)</div>
                </div>
            </div>

            <div class="mt-3">
                <p>@RenderSection("ErrorMessage", required: false)</p>
                <div class="mt-3">
                    @RenderSection("ErrorActions", required: false)
                </div>
            </div>
        </div>
    </div>
</body>
</html>