@{
    Layout = null;

    var sliderImages = new List<string>();

    try
    {
        // Lấy ảnh dạng 01.jpg, 02.jpg...
        var sliderDir = Server.MapPath("~/Content/Images/Slider");

        if (!string.IsNullOrEmpty(sliderDir) && System.IO.Directory.Exists(sliderDir))
        {
            sliderImages = System.IO.Directory.GetFiles(sliderDir)
                .Where(f => System.Text.RegularExpressions.Regex.IsMatch(
                    System.IO.Path.GetFileNameWithoutExtension(f),
                    @"^\d+$"
                ))
                .OrderBy(f => int.Parse(System.IO.Path.GetFileNameWithoutExtension(f)))
                .Select(f => Url.Content("~/Content/Images/Slider/" + System.IO.Path.GetFileName(f)))
                .ToList();
        }
    }
    catch
    {
        // ignore and fall back to default images
    }

    if (sliderImages == null || !sliderImages.Any())
    {
        // fallback remote image to avoid throwing on missing files
        sliderImages = new List<string>
        {
            "https://images.unsplash.com/photo-1511690743698-d9d85f2fbf38?q=80&w=1920"
        };
    }
}

<link rel="stylesheet" href="https://unpkg.com/swiper/swiper-bundle.min.css" />

<style>
    .hero-swiper {
        width: 100%;
        height: 600px;
        position: relative;
    }

    .tn-hero {
        width: 100%;
        height: 600px;
        display: flex;
        align-items: center;
        justify-content: center;
        position: relative;
        overflow: hidden;
    }

    /* ================================
       ẢNH NỀN – TỐI ƯU KHÔNG LÀM TỐI
       ================================ */
    .tn-hero-bg {
        position: absolute;
        inset: 0;
        background-size: cover;
        background-position: center;
        background-repeat: no-repeat;
        z-index: 1;
        /* scale nhỏ hơn để ảnh không vỡ, sáng hơn */
        transform: scale(1.05);
        transition: transform 4s ease;
    }

    /* Hiệu ứng zoom nhẹ khi active - không phá nét */
    .swiper-slide-active .tn-hero-bg {
        transform: scale(1.12);
    }

    /* FIX SWIPER FADE LÀM TỐI ẢNH */
    .swiper-fade .swiper-slide {
        opacity: 0 !important;
        transition-property: opacity !important;
    }

    .swiper-fade .swiper-slide-active {
        opacity: 1 !important;
    }

    /* KHỐI CHỮ */
    .tn-hero-content {
        position: absolute;
        right: 120px;
        top: 50%;
        transform: translateY(-50%);
        text-align: center;
        max-width: 600px;
        padding-right: 40px;
        z-index: 3;
        display: flex;
        flex-direction: column;
        align-items: center;
    }

        /* Chữ phát sáng */
        .tn-hero-content h1,
        .tn-hero-content p {
            text-shadow: 0 0 12px rgba(255,255,255,0.25), 0 0 22px rgba(0,0,0,0.65), 0 4px 25px rgba(0,0,0,0.85);
        }

    .tn-hero-title {
        font-size: 4.4rem;
        font-weight: 900;
        text-transform: uppercase;
        line-height: 1.15;
        letter-spacing: 3px;
    }

    .tn-hero-desc {
        font-size: 1.8rem;
        margin-top: 10px;
    }

    /* THANH DỌC PHÁT SÁNG */
    .tn-hero-content::after {
        content: "";
        position: absolute;
        right: -25px;
        top: 50%;
        transform: translateY(-50%);
        width: 15px;
        height: 85%;
        background: white;
        border-radius: 10px;
        box-shadow: 0 0 25px rgba(255,255,255,0.95);
        opacity: 0.95;
        z-index: -1;
    }

    /* Responsive */
    @@media (max-width: 992px) {
        .tn-hero {
            height: 480px;
        }

        .hero-swiper {
            height: 480px;
        }

        .tn-hero-content {
            right: 0;
            top: auto;
            transform: none;
            margin: 0 auto;
            padding-right: 0;
        }

            .tn-hero-content::after {
                display: none;
            }

        .tn-hero-title {
            font-size: 2.8rem;
        }

        .tn-hero-desc {
            font-size: 1.3rem;
        }
    }

    /* Button Slide */
    .swiper-button-next,
    .swiper-button-prev {
        color: #fff;
        text-shadow: 0 0 8px rgba(0,0,0,0.5);
        transform: scale(1.3);
    }

    .swiper-pagination-bullet-active {
        background: #16a34a;
    }
</style>

<!-- ===== SLIDER ===== -->
<div class="swiper hero-swiper swiper-fade">
    <div class="swiper-wrapper">

        @foreach (var img in sliderImages)
        {
            <div class="swiper-slide">
                <section class="tn-hero text-white">
                    <div class="tn-hero-bg" style="background-image:url('@img');"></div>

                    <div class="tn-hero-content">
                        <h1 class="tn-hero-title">Tạp Hóa <br /> Thanh Nhàn</h1>
                        <p class="tn-hero-desc">Tươi – Sạch – Giá tốt <br /> Phục vụ tận tâm hơn 15 năm</p>
                    </div>
                </section>
            </div>
        }

    </div>

    <div class="swiper-pagination"></div>
    <div class="swiper-button-prev"></div>
    <div class="swiper-button-next"></div>
</div>

<script src="https://unpkg.com/swiper/swiper-bundle.min.js"></script>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        new Swiper('.hero-swiper', {
            loop: true,
            effect: 'fade',

            autoplay: {
                delay: 3500,
                disableOnInteraction: false
            },

            fadeEffect: { crossFade: false }, // KHÔNG làm tối slide

            pagination: {
                el: '.swiper-pagination',
                clickable: true
            },

            navigation: {
                nextEl: '.swiper-button-next',
                prevEl: '.swiper-button-prev'
            }
        });
    });
</script>
