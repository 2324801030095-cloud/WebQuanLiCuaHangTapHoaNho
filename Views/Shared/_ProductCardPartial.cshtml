@model WebQuanLiCuaHangTapHoa.Models.SanPhamView

<div class="card card-soft h-100">

    <img class="card-img-top product-img"
         src="@Url.Content("~/Content/Images/" + Model.HinhAnh)"
         alt="@Model.TenSP">

    <div class="p-3">

        <h5 class="mb-1">@Model.TenSP</h5>

        <div class="price mb-2">
            @String.Format("{0:N0}₫", Model.GiaBan)
        </div>

        <div class="stock-wrap mb-3">
            @{
                var pct = Model.Ton <= 0 ? 2 : (Model.Ton > 100 ? 100 : Model.Ton);
            }
            <div class="stock-bar"><span style="width:@pct%"></span></div>
            <small class="text-muted">Tồn: @Model.Ton</small>
        </div>

        <div class="d-flex gap-2">

            <a class="btn btn-outline-success flex-fill"
               href="@Url.Action("ChiTiet", "SanPham", new { id = Model.MaSP })">
                <i class="bi bi-eye me-1"></i> Xem
            </a>

            <!-- Nút thêm giỏ hàng CHUẨN -->
            <button type="button"
                    class="btn btn-brand flex-fill btn-addcart"
                    data-id="@Model.MaSP"
                    data-img="@Url.Content("~/Content/Images/" + Model.HinhAnh)">
                <i class="bi bi-bag-plus me-1"></i> Thêm
            </button>

        </div>

    </div>
</div>
