@* _FooterPartial.cshtml *@

<style>
    /* --- FOOTER MAIN STYLES (THEO MÀU TRONG ẢNH) --- */
    .app-footer {
        background: linear-gradient(180deg, #F5F5EB 0%, #E8F7ED 100%); /* Tông nền nhạt */
        color: #166534; /* Màu chữ xanh lá đậm */
        font-size: 0.95rem;
        position: relative;
        overflow: hidden;
    }

        .app-footer h5,
        .app-footer h6 {
            color: #166534;
            font-weight: 700;
            letter-spacing: 0.5px;
            margin-bottom: 1.2rem;
        }

    /* Thương hiệu */
    .brand-title {
        font-family: 'Segoe UI', sans-serif;
        font-weight: 800 !important;
        background: linear-gradient(to right, #4ade80, #22c55e);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }

    /* --- LINKS STYLE --- */
    .footer-link-list li {
        margin-bottom: 10px;
    }

    .footer-link-list a {
        color: #166534b3;
        text-decoration: none;
        transition: all 0.3s ease;
        display: inline-block;
    }

        .footer-link-list a:hover {
            color: #0f5132;
            transform: translateX(5px);
        }

    /* --- FORM INPUT --- */
    .footer-input {
        background: white;
        border: 1px solid #b7dbc5;
        color: #166534;
        border-radius: 6px;
    }

        .footer-input:focus,
        .footer-input:hover {
            background: #ffffff;
            border-color: #22c55e;
            box-shadow: 0 0 0 3px rgba(34, 197, 94, 0.25);
        }

        .footer-input::placeholder {
            color: #6b8a75;
        }

    /* --- SOCIAL ICONS --- */
    .social-btn {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        background: rgba(255, 255, 255, 0.1);
        display: flex;
        justify-content: center;
        align-items: center;
        color: #ffffff !important;
        font-size: 1.2rem;
        transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        position: relative;
        text-decoration: none;
        box-shadow: 0 0 8px rgba(255, 255, 255, 0.3);
    }

    .sb-fb {
        background: linear-gradient(45deg, #1877F2, #0099FF);
        box-shadow: 0 0 10px rgba(24, 119, 242, 0.5);
    }

        .sb-fb:hover {
            box-shadow: 0 0 25px #1877F2;
            transform: translateY(-5px);
        }

    .sb-ins {
        background: radial-gradient(circle at 30% 107%, #fdf497 0%, #fd5949 45%, #d6249f 60%, #285AEB 90%);
        box-shadow: 0 0 10px rgba(214, 36, 159, 0.5);
    }

        .sb-ins:hover {
            box-shadow: 0 0 25px #d6249f;
            transform: translateY(-5px);
        }

    .sb-yt {
        background: linear-gradient(45deg, #FF0000, #ff4b4b);
        box-shadow: 0 0 10px rgba(255, 0, 0, 0.5);
    }

        .sb-yt:hover {
            box-shadow: 0 0 25px #ff0000;
            transform: translateY(-5px);
        }

    .sb-tik {
        background: linear-gradient(45deg, #000000, #25F4EE, #FE2C55);
        box-shadow: 0 0 10px rgba(37, 244, 238, 0.5);
    }

        .sb-tik:hover {
            box-shadow: 0 0 25px rgba(37, 244, 238, 0.7);
            transform: translateY(-5px);
        }

    /* --- FOOTER BOTTOM (2 DÒNG — CĂN GIỮA) --- */
    .footer-bottom {
        text-align: center;
        color: #166534;
        padding-top: 20px;
        padding-bottom: 10px;
        line-height: 1.6;
        font-weight: 500;
    }
</style>

<footer id="footer-contact" class="app-footer pt-5 pb-3">
    <div class="container">
        <div class="row g-4">

            <div class="col-12 col-md-4">
                <div class="d-flex align-items-center mb-3">
                    <div class="d-flex align-items-center justify-content-center bg-white rounded-circle me-2"
                         style="width:40px; height:40px;">
                        <i class="bi bi-shop fs-5 text-success"></i>
                    </div>
                    <h5 class="m-0 brand-title">THANH NHAN GROCERY</h5>
                </div>

                <p class="mb-4" style="max-width: 300px; color:#166534b3;">
                    Tươi – Nhanh – Giá tốt. Cam kết thực phẩm sạch, giao hàng tận nơi và phục vụ tận tâm mỗi ngày.
                </p>

                <div class="d-flex gap-3">
                    <a href="#" class="social-btn sb-fb"><i class="bi bi-facebook"></i></a>
                    <a href="#" class="social-btn sb-ins"><i class="bi bi-instagram"></i></a>
                    <a href="#" class="social-btn sb-yt"><i class="bi bi-youtube"></i></a>
                    <a href="#" class="social-btn sb-tik"><i class="bi bi-tiktok"></i></a>
                </div>
            </div>

            <div class="col-6 col-md-2">
                <h6 class="text-uppercase">Khám Phá</h6>
                <ul class="list-unstyled footer-link-list">
                    <li><a href="#best-sellers">Bán chạy</a></li>
                    <li><a href="#featured">Nổi bật</a></li>
                    <li><a href="#top-products">Top hôm nay</a></li>
                    <li><a href="#knowledge">Góc nội trợ</a></li>
                </ul>
            </div>

            <div class="col-6 col-md-3">
                <h6 class="text-uppercase">Hỗ Trợ KH</h6>
                <ul class="list-unstyled footer-link-list">
                    <li><a href="#">Trung tâm trợ giúp</a></li>
                    <li><a href="#">Chính sách giao hàng</a></li>
                    <li><a href="#">Đổi trả & Hoàn tiền</a></li>
                    <li><a href="#">Bảo mật thông tin</a></li>
                </ul>
            </div>

            <div class="col-12 col-md-3">
                <h6 class="text-uppercase">Nhận Ưu Đãi HOT</h6>
                <p class="small mb-3" style="color:#166534b3;">
                    Đăng ký để nhận voucher giảm giá 10% cho đơn hàng đầu tiên.
                </p>
                <form class="d-flex gap-2">
                    <input type="email" class="form-control footer-input" placeholder="Email của bạn..." required />
                    <button class="btn btn-success fw-bold px-3" type="submit">
                        <i class="bi bi-send-fill"></i>
                    </button>
                </form>
            </div>

        </div>

        <!-- FOOTER BOTTOM 2 DÒNG CĂN GIỮA -->
        <div class="footer-bottom mt-4">
            <div>
                © @DateTime.Now.Year <strong>Thanh Nhan Grocery</strong>. All rights reserved.
            </div>
            <div>
                Designed by <strong>Apollo Dev</strong>
            </div>
        </div>

    </div>
</footer>
