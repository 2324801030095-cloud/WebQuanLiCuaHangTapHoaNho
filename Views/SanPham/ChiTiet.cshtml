@model WebQuanLiCuaHangTapHoa.Models.ViewModels.SanPhamDetailVM

@{
    ViewBag.Title = Model.TenSP;
    int phanTram = Model.Ton <= 0 ? 5 : (Model.Ton > 100 ? 100 : Model.Ton);
    bool coKM = Model.Giam.HasValue && Model.Giam.Value > 0 && Model.GiaSauKM < Model.GiaBan;
}

<section class="container py-4">

    <!-- BREADCRUMB -->
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="@Url.Action("Index","Home")">Trang chủ</a></li>
            <li class="breadcrumb-item">
                <a href="@Url.Action("DanhSach","DanhMuc", new { maDM = Model.MaDM })">@Model.TenDM</a>
            </li>
            <li class="breadcrumb-item active" aria-current="page">@Model.TenSP</li>
        </ol>
    </nav>

    <div class="row g-4">

        <!-- ẢNH SẢN PHẨM -->
        <div class="col-lg-5">
            <div class="card shadow-sm">
                <img src="@Url.Content("~/Content/Images/" + Model.HinhAnh)"
                     alt="@Model.TenSP"
                     class="product-detail-img" />
            </div>
        </div>

        <!-- THÔNG TIN -->
        <div class="col-lg-7">
            <h1 class="h3 mb-3">@Model.TenSP</h1>
            <div class="text-muted mb-2">Đơn vị tính: <strong>@Model.DonViTinh</strong></div>

            <!-- GIÁ -->
            <div class="mb-3">
                @if (coKM)
                {
                    <div class="d-flex align-items-baseline gap-2">
                        <div class="fs-4 fw-bold text-danger">@String.Format("{0:N0} ₫", Model.GiaSauKM)</div>
                        <div class="text-muted text-decoration-line-through">@String.Format("{0:N0} ₫", Model.GiaBan)</div>
                        <span class="badge bg-danger">
                            -@((Model.Giam ?? 0).ToString("0.#"))%
                        </span>
                    </div>
                    <div class="small text-muted">
                        KM: @(Model.TenKM) (
                        @(Model.TuNgay.HasValue ? Model.TuNgay.Value.ToString("dd/MM/yyyy") : "")
                        -
                        @(Model.DenNgay.HasValue ? Model.DenNgay.Value.ToString("dd/MM/yyyy") : "")
                        )
                    </div>
                }
                else
                {
                    <div class="fs-4 fw-bold text-success">@String.Format("{0:N0} ₫", Model.GiaBan)</div>
                }
            </div>

            <!-- TỒN KHO -->
            <div class="mb-3">
                <div class="progress" style="height: 10px;">
                    <div class="progress-bar bg-success" style="width:@phanTram%"></div>
                </div>
                <small class="text-muted">Còn lại: @Model.Ton sản phẩm</small>
            </div>

            <!-- MÔ TẢ NGẮN -->
            @if (!string.IsNullOrWhiteSpace(Model.MoTaNgan))
            {
                <p class="lead mt-3">@Model.MoTaNgan</p>
            }

            <!-- NÚT -->
            <div class="d-flex gap-2 mt-4 mb-4">
                <button class="btn btn-primary"
                        onclick="addToCartDemo(@Model.MaSP,'@Model.TenSP',@(Model.GiaSauKM > 0 ? Model.GiaSauKM : Model.GiaBan),'@Model.HinhAnh')">
                    <i class="bi bi-bag-plus"></i> Thêm vào giỏ
                </button>
                <a class="btn btn-outline-success"
                   href="@Url.Action("DanhSach","DanhMuc", new { maDM = Model.MaDM })">
                    <i class="bi bi-arrow-left"></i> Về danh mục
                </a>
            </div>

            <!-- MÔ TẢ CHI TIẾT -->
            <div class="card p-3 shadow-sm">
                <h5 class="mb-2">Mô tả chi tiết</h5>
                <div style="white-space: pre-line;">
                    @Html.Raw(string.IsNullOrEmpty(Model.MoTaChiTiet) ? "Đang cập nhật..." : Model.MoTaChiTiet)
                </div>
            </div>
        </div>
    </div>

    <!-- SẢN PHẨM LIÊN QUAN -->
    <section class="mt-5">
        <h4 class="mb-3">Sản phẩm liên quan</h4>
        @Html.Action("LienQuan", "SanPham", new { id = Model.MaSP, take = 6 })
    </section>

</section>

@section styles{
    <style>

        .product-detail-img {
            width: 100%;
            height: 380px;
            object-fit: contain;
            background: #fff;
            padding: 10px;
            border-radius: 12px;
        }

        /* Ảnh sản phẩm trong CARDS (liên quan) */
        .card-img-top {
            width: 100%;
            height: 180px !important; /* chiều cao chuẩn như trang danh mục */
            object-fit: contain !important; /* ⭐ KHÔNG CẮT ẢNH */
            background: #fff;
            padding: 6px;
        }
    </style>
}

@section scripts{
    <script>
        function addToCartDemo(id, name, price, img) {
            alert("Đã thêm: " + name + " - " + price.toLocaleString() + "₫");
        }
    </script>
}
