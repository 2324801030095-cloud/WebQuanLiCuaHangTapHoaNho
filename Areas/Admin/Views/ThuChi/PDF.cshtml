@model List<WebQuanLiCuaHangTapHoa.Models.ThuChi>

@{
    Layout = null;
    var tongThu = Model.Where(x => x.Loai == "Thu").Sum(x => x.SoTien);
    var tongChi = Model.Where(x => x.Loai == "Chi").Sum(x => x.SoTien);
    var loiNhuan = tongThu - tongChi;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>BÁO CÁO THU – CHI</title>
    <style>
        body {
            font-family: DejaVu Sans, sans-serif;
            font-size: 13px;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 15px;
        }

        th, td {
            border: 1px solid #999;
            padding: 6px;
            text-align: center;
        }

        th {
            background: #e6e6e6;
        }

        h2 {
            text-align: center;
            margin-bottom: 5px;
        }

        .summary {
            margin-top: 20px;
        }
    </style>
</head>
<body>

    <h2>BÁO CÁO THU – CHI</h2>
    <div>Ngày xuất: @DateTime.Now.ToString("dd/MM/yyyy HH:mm")</div>

    <table>
        <thead>
            <tr>
                <th>Ngày</th>
                <th>Loại</th>
                <th>Diễn giải</th>
                <th>Số tiền</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Ngay.ToString("dd/MM/yyyy")</td>
                    <td>@item.Loai</td>
                    <td>@String.Format("{0:N0}", item.SoTien)</td>
                </tr>
            }
        </tbody>
    </table>

    <div class="summary">
        <p><strong>Tổng thu:</strong> @String.Format("{0:N0} ₫", tongThu)</p>
        <p><strong>Tổng chi:</strong> @String.Format("{0:N0} ₫", tongChi)</p>
        <p><strong>Lợi nhuận:</strong> @String.Format("{0:N0} ₫", loiNhuan)</p>
    </div>

</body>
</html>
