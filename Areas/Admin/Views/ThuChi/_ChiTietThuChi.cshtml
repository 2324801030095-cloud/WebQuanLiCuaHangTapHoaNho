@model WebQuanLiCuaHangTapHoa.Models.ThuChi

<div class="modal fade" id="modalTC" tabindex="-1">
    <div class="modal-dialog modal-md">
        <div class="modal-content">

            <div class="modal-header bg-info text-white">
                <h5 class="modal-title">
                    <i class="fa-solid fa-eye"></i> Chi tiết Thu – Chi
                </h5>
                <button class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">

                <p><strong>Mã TC:</strong> @Model.MaTC</p>
                <p><strong>Ngày:</strong> @Model.Ngay.ToString("dd/MM/yyyy")</p>
                <p><strong>Loại:</strong> @Model.Loai</p>
                <p><strong>Số tiền:</strong> @String.Format("{0:N0} ₫", Model.SoTien)</p>
                <p><strong>Ghi chú:</strong> @Model.DienGiai</p>

            </div>

            <div class="modal-footer">
                <button class="btn btn-secondary" data-bs-dismiss="modal">Đóng</button>
            </div>

        </div>
    </div>
</div>
