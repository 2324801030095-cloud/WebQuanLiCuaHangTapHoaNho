@model WebQuanLiCuaHangTapHoa.Models.ThuChi

<div class="modal fade" id="modalTC" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">

            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title"><i class="fa-solid fa-edit"></i> Cập nhật Thu – Chi</h5>
                <button class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">

                @Html.HiddenFor(m => m.MaTC)

                <div class="mb-2">
                    <label>Loại:</label>
                    @Html.DropDownList("Loai", (SelectList)ViewBag.Loai,
                        new { @class = "form-control" })
                </div>

                <div class="mb-2">
                    <label>Số tiền:</label>
                    @Html.TextBoxFor(m => m.SoTien, new { @class = "form-control", type = "number" })
                </div>

                <div class="mb-2">
                    <label>Ngày:</label>
                    @Html.TextBoxFor(m => m.Ngay, new { @class = "form-control", type = "date" })
                </div>

                <div class="mb-2">
                    <label>Ghi chú:</label>
                    @Html.TextAreaFor(m => m.DienGiai, new { @class = "form-control", rows = 2 })
                </div>

            </div>

            <div class="modal-footer">
                <button class="btn btn-secondary" data-bs-dismiss="modal">Đóng</button>
                <button class="btn btn-primary" id="btnUpdateTC">Cập nhật</button>
            </div>

        </div>
    </div>
</div>

<script>
    document.getElementById("btnUpdateTC").onclick = function () {

        const data = {
            MaTC: document.getElementById("MaTC").value,
            Loai: document.getElementById("Loai").value,
            SoTien: document.getElementById("SoTien").value,
            Ngay: document.getElementById("Ngay").value,
            GhiChu: document.getElementById("GhiChu").value
        };

        fetch("/Admin/ThuChi/Sua", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify(data)
        })
        .then(r => r.json())
        .then(d => {
            alert(d.message);
            if (d.success) location.reload();
        });
    };
</script>

