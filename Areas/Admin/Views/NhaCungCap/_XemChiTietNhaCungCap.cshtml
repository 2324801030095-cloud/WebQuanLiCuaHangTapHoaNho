@model WebQuanLiCuaHangTapHoa.Models.NhaCungCap

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

<div class="modal fade" id="modalNCC" tabindex="-1">
    <div class="modal-dialog modal-xl modal-dialog-centered">
        <div class="modal-content">

            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title">
                    <i class="fa-solid fa-eye"></i> Thông Tin Nhà Cung Cấp
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">

                <!-- ========== Thông tin chi tiết ========== -->
                <div class="p-3 border rounded mb-3" style="background:#f8fafc;">
                    <div class="row">

                        <div class="col-md-6 mb-3">
                            <label class="fw-bold text-primary">Mã NCC:</label><br />
                            <span>@Model.MaNCC</span>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label class="fw-bold text-primary">Tên Nhà Cung Cấp:</label><br />
                            <span>@Model.TenNCC</span>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label class="fw-bold text-primary">Số Điện Thoại:</label><br />
                            <span>@Model.SoDT</span>
                        </div>

                        <div class="col-md-12 mb-3">
                            <label class="fw-bold text-primary">Địa Chỉ:</label><br />
                            <span id="nccAddress">@Model.DiaChi</span>

                            <a id="openGgMaps"
                               href="#"
                               target="_blank"
                               class="btn btn-sm btn-outline-primary ms-2">
                                <i class="fa-solid fa-location-arrow"></i> Chỉ đường Google Maps
                            </a>
                        </div>

                    </div>
                </div>


                <!-- ========== BẢN ĐỒ ========== -->
                <label class="fw-bold mb-2">Vị trí trên bản đồ:</label>
                <div id="viewNCCMap"
                     style="height:500px; width:100%; border:1px solid #d5dbe4; border-radius:10px;">
                </div>

            </div>

            <div class="modal-footer">
                <button class="btn btn-secondary" data-bs-dismiss="modal">
                    <i class="fa-solid fa-xmark"></i> Đóng
                </button>
            </div>

        </div>
    </div>
</div>

<script>
    const VIEW_GEOCODE_API = "https://nominatim.openstreetmap.org/search?format=json&q=";

    async function initNCCViewMap() {
        const addr = document.getElementById("nccAddress").innerText;
        if (!addr) return;

        const res = await fetch(VIEW_GEOCODE_API + encodeURIComponent(addr));
        const data = await res.json();

        let lat = 10.762622, lon = 106.660172;
        if (data && data.length > 0) {
            lat = parseFloat(data[0].lat);
            lon = parseFloat(data[0].lon);
        }

        // Google Maps link
        document.getElementById("openGgMaps").href =
            `https://www.google.com/maps/search/?api=1&query=${lat},${lon}`;

        const map = L.map("viewNCCMap").setView([lat, lon], 15);
        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png').addTo(map);

        L.marker([lat, lon]).addTo(map)
            .bindPopup(`<b>${addr}</b>`)
            .openPopup();

        setTimeout(() => map.invalidateSize(), 400);
    }

    document.addEventListener("shown.bs.modal", (e) => {
        if (e.target.id === "modalNCC") initNCCViewMap();
    });
</script>
