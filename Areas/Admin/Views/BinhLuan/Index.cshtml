@model PagedList.IPagedList<WebQuanLiCuaHangTapHoa.Models.DanhGia>
@using PagedList.Mvc;

@{
    ViewBag.Title = "Quản lý bình luận";
    Layout = "~/Areas/Admin/Views/Shared/_LayoutAdmin.cshtml";
}

<div class="container-fluid p-4">
    <div class="text-center mb-3">
        <h4 class="page-title">
            <i class="fa-solid fa-comments"></i>
            Quản lý bình luận / đánh giá
        </h4>
    </div>

    <!-- Filter -->
    <form method="get" class="filter-bar bg-white p-3 rounded shadow-sm mb-3">
        <div class="d-flex gap-2 flex-wrap">
            <input type="text" name="search" value="@ViewBag.Search" placeholder="Tìm kiếm..." class="form-control" style="width:250px;">
            <select name="trangThai" class="form-select" style="width:180px;">
                <option value="">Tất cả</option>
                <option value="true" @(ViewBag.TrangThai == true ? "selected" : "")>Đã duyệt</option>
                <option value="false" @(ViewBag.TrangThai == false ? "selected" : "")>Chờ duyệt</option>
            </select>
            <button type="submit" class="btn btn-primary"><i class="fa-solid fa-filter"></i> Lọc</button>
            <a href="@Url.Action("Index")" class="btn btn-secondary"><i class="fa-solid fa-rotate-right"></i> Làm mới</a>
        </div>
    </form>

    <!-- Table -->
    <div class="card shadow-sm">
        <div class="table-responsive">
            <table class="table table-bordered mb-0">
                <thead>
                    <tr>
                        <th>Mã</th>
                        <th>Khách hàng</th>
                        <th>Sản phẩm</th>
                        <th>Điểm</th>
                        <th>Nội dung</th>
                        <th>Ngày</th>
                        <th>Trạng thái</th>
                        <th>Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Count == 0)
                    {
                        <tr>
                            <td colspan="8" class="text-center text-muted py-4">Không có bình luận nào.</td>
                        </tr>
                    }
                    else
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.MaDanhGia</td>
                                <td>@(item.KhachHang?.TenKH ?? "N/A")</td>
                                <td>@(item.SanPham?.TenSP ?? "Đánh giá cửa hàng")</td>
                                <td>
                                    @for (int i = 1; i <= 5; i++)
                                    {
                                        <i class="fa-solid fa-star @(i <= item.Diem ? "text-warning" : "text-muted")"></i>
                                    }
                                </td>
                                <td>@(item.NoiDung?.Length > 50 ? item.NoiDung.Substring(0, 50) + "..." : item.NoiDung)</td>
                                <td>@item.NgayDanhGia.ToString("dd/MM/yyyy HH:mm")</td>
                                <td>
                                    @if (item.TrangThai)
                                    {
                                        <span class="badge bg-success">Đã duyệt</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-warning">Chờ duyệt</span>
                                    }
                                </td>
                                <td>
                                    <button class="btn btn-info btn-sm" onclick="viewDetail(@item.MaDanhGia)" title="Xem">
                                        <i class="fa-solid fa-eye"></i>
                                    </button>
                                    @if (!item.TrangThai)
                                    {
                                        <button class="btn btn-success btn-sm" onclick="duyet(@item.MaDanhGia)" title="Duyệt">
                                            <i class="fa-solid fa-check"></i>
                                        </button>
                                    }
                                    <button class="btn btn-danger btn-sm" onclick="xoa(@item.MaDanhGia)" title="Xóa">
                                        <i class="fa-solid fa-trash"></i>
                                    </button>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>

        <div class="card-footer bg-white text-center">
            @Html.PagedListPager(Model, page => Url.Action("Index", new { page, search = ViewBag.Search, trangThai = ViewBag.TrangThai }),
            new PagedListRenderOptions
            {
                Display = PagedListDisplayMode.IfNeeded,
                DisplayLinkToFirstPage = PagedListDisplayMode.Always,
                DisplayLinkToLastPage = PagedListDisplayMode.Always,
                DisplayLinkToPreviousPage = PagedListDisplayMode.Always,
                DisplayLinkToNextPage = PagedListDisplayMode.Always,
                DisplayEllipsesWhenNotShowingAllPageNumbers = true,
                MaximumPageNumbersToDisplay = 5,
                UlElementClasses = new[] { "pagination" }
            })
        </div>
    </div>
</div>

<div id="modalContainer"></div>

<script>
    function viewDetail(id) {
        fetch(`/Admin/BinhLuan/ChiTiet/${id}`)
            .then(r => r.text())
            .then(html => {
                const modalContainer = document.getElementById("modalContainer");
                if (window.renderHtml) {
                    window.renderHtml(modalContainer, html);
                } else {
                    modalContainer.innerHTML = html;
                }
                new bootstrap.Modal(document.getElementById("modalDetail")).show();
            });
    }

    function duyet(id) {
        if (!confirm("Duyệt bình luận này?")) return;
        fetch("/Admin/BinhLuan/Duyet", {
            method: "POST",
            headers: { "Content-Type": "application/x-www-form-urlencoded" },
            body: `id=${id}`
        })
        .then(r => r.json())
        .then(d => {
            alert(d.message);
            if (d.success) location.reload();
        });
    }

    function xoa(id) {
        if (!confirm("Xóa bình luận này?")) return;
        fetch("/Admin/BinhLuan/Xoa", {
            method: "POST",
            headers: { "Content-Type": "application/x-www-form-urlencoded" },
            body: `id=${id}`
        })
        .then(r => r.json())
        .then(d => {
            alert(d.message);
            if (d.success) location.reload();
        });
    }
</script>

