                                            <td class="text-center">@String.Format("{0:N0}", item.DonGia)d</td>
                                            <td class="text-end fw-bold text-danger">@String.Format("{0:N0}", item.ThanhTien)d</td>
                                        </tr>
                                    }
                                </tbody>
                                <tfoot>
