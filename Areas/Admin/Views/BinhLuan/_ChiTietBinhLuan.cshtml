@using WebQuanLiCuaHangTapHoa.Models.ViewModels
@model DanhGiaChiTietViewModel

@{
    var dg = Model?.DanhGia;
    var order = Model?.HoaDonDetails?.FirstOrDefault();
    if (dg == null)
    {
        <div class="alert alert-danger">Kh¶ng th? t?i chi ti?t bšnh lu?n.</div>
        return;
    }
}

<style>
    .comment-detail-header {
        background: linear-gradient(135deg, #0ea5e9, #14b8a6);
        color: #fff;
    }

    .comment-meta {
        font-size: 0.95rem;
    }

    .product-thumb {
        width: 54px;
        height: 54px;
        object-fit: cover;
        border-radius: 8px;
        border: 1px solid #e5e7eb;
    }

    .badge-reviewed {
