                                        <tr>
                                            <td>
                                                <div class="d-flex align-items-center gap-2">
                                                    @if (!string.IsNullOrWhiteSpace(item.HinhAnh))
                                                    {
                                                        <img src="@Url.Content("~/Content/Images/" + item.HinhAnh)" alt="@item.TenSP" class="product-thumb" />
                                                    }
