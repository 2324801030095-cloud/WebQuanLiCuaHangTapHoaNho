                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="row g-3 mb-3">
                    <div class="col-md-6 comment-meta">
                        <strong>MÐ dÃnh giÃ:</strong> #@dg.MaDanhGia
                    </div>
                    <div class="col-md-6 comment-meta">
                        <strong>NgÁy dÃnh giÃ:</strong> @dg.NgayDanhGia.ToString("dd/MM/yyyy HH:mm")
                    </div>
                    <div class="col-md-6 comment-meta">
                        <strong>KhÃch hÁng:</strong> @(dg.KhachHang?.TenKH ?? "N/A")
                    </div>
                    <div class="col-md-6 comment-meta">
                        <strong>S?n ph?m:</strong> @(dg.SanPham?.TenSP ?? "ÅÃnh giÃ c?a hÁng")
                    </div>
                </div>

                <div class="mb-3">
                    <strong>Åi?m dÃnh giÃ:</strong>
                    <div class="mt-1">
                        @for (int i = 1; i <= 5; i++)
                        {
                            <i class="fa-solid fa-star @(i <= dg.Diem ? "text-warning" : "text-muted")"></i>
                        }
                        <span class="ms-2">(@dg.Diem/5)</span>
                    </div>
                </div>

                <div class="mb-3">
                    <strong>N?i dung:</strong>
                    <div class="p-3 bg-light rounded mt-2">@dg.NoiDung</div>
                </div>

                <div class="mb-4">
                    <strong>Tr?ng thÃi:</strong>
                    @if (dg.TrangThai)
                    {
                        <span class="badge bg-success ms-2">ÅÐ duy?t</span>
                    }
                    else
                    {
                        <span class="badge bg-warning ms-2">Ch? duy?t</span>
                    }
                </div>

                <h6 class="mb-3"><i class="fa-solid fa-receipt me-2 text-success"></i>Åon hÁng cµ s?n ph?m du?c dÃnh giÃ</h6>

                @if (order == null)
                {
                    <div class="alert alert-info">
                        @if (dg.MaSP.HasValue)
                        {
                            <span>Kh¶ng tšm th?y hµa don ch?a s?n ph?m nÁy.</span>
                        }
                        else
                        {
                            <span>Åãy lÁ dÃnh giÃ c?a hÁng, kh¶ng g?n v?i hµa don c? th?.</span>
                        }
                    </div>
                }
                else
                {
                    <div class="card">
                        <div class="card-header bg-light">
                            <strong>Hµa don #@order.MaHD</strong>
