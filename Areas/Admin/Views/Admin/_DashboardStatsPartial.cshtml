        color: #000 !important;
    }

</style>


<script>
    document.addEventListener("DOMContentLoaded", function () {
        document.querySelectorAll(".kpi-box").forEach(box => {
            let numberEl = box.querySelector(".count-up");
            let moneyEl = box.querySelector(".money-up");
            if (numberEl) {
                let val = parseInt(box.getAttribute("data-count") || 0);
                animateCountUp(numberEl, val);
            }
            if (moneyEl) {
                let val = parseInt(box.getAttribute("data-money") || 0);
                animateMoney(moneyEl, val);
            }
        });
    });

    function animateCountUp(el, target, duration = 1500) {
        let start = 0;
        let increment = target / (duration / 16);
        let timer = setInterval(() => {
            start += increment;
            if (start >= target) {
                start = target;
                clearInterval(timer);
            }
            el.textContent = Math.floor(start);
        }, 16);
    }

    function animateMoney(el, target, duration = 1600) {
        let start = 0;
        let increment = target / (duration / 16);
        let timer = setInterval(() => {
            start += increment;
            if (start >= target) {
                start = target;
                clearInterval(timer);
            }
            el.textContent = new Intl.NumberFormat().format(Math.floor(start)) + " ₫";
        }, 16);
    }
</script>



<script>
    // ===============================
    //  3 NÚT LỌC A/B/C (AJAX)
    // ===============================
   $(document).on("click", ".metric-btn", function () {
    var metric = $(this).data("metric");
    var from = $("input[name='from']").val();
    var to = $("input[name='to']").val();
    var pageKH = $("#TopKHPage").val() || 1;

    $.ajax({
        url: '@Url.Action("FilterDashboard", "Admin", new { area = "Admin" })',
        type: 'GET',
        data: {
            customerMetric: metric,
            from: from,
            to: to,
            pageKH: pageKH
        },
        success: function (html) {
            const container = document.getElementById("statsSection");
            if (window.renderHtml) {
                window.renderHtml(container, html);
            } else if (container) {
                container.innerHTML = html;
            }
            if (window.initProfitChart) window.initProfitChart();
            if (window.hookActionButtons) window.hookActionButtons();
        }
    });
});

    // ===============================
    //  PHÂN TRANG TOP KHÁCH HÀNG (AJAX)
    // ===============================
    $(document).on("click", ".pagination a", function (e) {
        if (!$(this).closest(".kh-pagination").length) return; // tránh chặn phân trang Top SP

        e.preventDefault();
        var url = $(this).attr("href");

        $.ajax({
            url: url.replace("/Admin/Admin/Index", "/Admin/Admin/FilterDashboard"),
        success: function (html) {
            const container = document.getElementById("statsSection");
            if (window.renderHtml) {
                window.renderHtml(container, html);
            } else if (container) {
                container.innerHTML = html;
            }
            if (window.initProfitChart) window.initProfitChart();
            if (window.hookActionButtons) window.hookActionButtons();
        }
    });
});
</script>
