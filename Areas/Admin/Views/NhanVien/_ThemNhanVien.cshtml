@model WebQuanLiCuaHangTapHoa.Models.NhanVien

<div class="modal fade" id="modalNV" tabindex="-1">
    <div class="modal-dialog modal-xl modal-dialog-centered">
        <div class="modal-content">

            <div class="modal-header bg-success text-white">
                <h5 class="modal-title"><i class="fa-solid fa-user-plus me-2"></i>Thêm Nhân Viên</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">

                <div class="row">
                    <!-- LEFT COLUMN: AVATAR -->
                    <div class="col-md-4 text-center">
                        <img id="previewImg" src="/Images/Employees/default.png"
                             class="rounded shadow"
                             style="width: 100%; max-width:260px; height:260px; object-fit:cover;" />

                        <div class="mt-3">
                            <label class="btn btn-outline-primary btn-sm">
                                <i class="fa-solid fa-image"></i> Chọn ảnh
                                <input type="file" id="imgInput" class="d-none" accept="image/*" />
                            </label>
                        </div>
                    </div>

                    <!-- RIGHT COLUMN: FORM -->
                    <div class="col-md-8">
                        <form id="formAddNV">

                            <div class="row mb-3">
                                <div class="col-md-6">
                                    <label class="form-label fw-bold">Tên Nhân Viên</label>
                                    <input class="form-control" name="TenNV" required />
                                </div>

                                <div class="col-md-6">
                                    <label class="form-label fw-bold">Số Điện Thoại</label>
                                    <input class="form-control" name="SoDT" />
                                </div>
                            </div>

                            <div class="mb-3">
                                <label class="form-label fw-bold">Email</label>
                                <input class="form-control" name="Email" />
                            </div>

                            <div class="row mb-3">
                                <div class="col-md-6">
                                    <label class="form-label fw-bold">Giới tính</label>
                                    <select class="form-select" name="GioiTinh">
                                        <option value="">— Chọn —</option>
                                        <option>Nam</option>
                                        <option>Nữ</option>
                                        <option>Khác</option>
                                    </select>
                                </div>

                                <div class="col-md-6">
                                    <label class="form-label fw-bold">Ngày sinh</label>
                                    <input type="date" class="form-control" name="NgaySinh" />
                                </div>
                            </div>

                            <div class="mb-3">
                                <label class="form-label fw-bold">Địa chỉ</label>
                                <input class="form-control" name="DiaChi" />
                            </div>

                            <div class="mb-3">
                                <label class="form-label fw-bold">CCCD / CMND</label>
                                <input class="form-control" name="CCCD" />
                            </div>

                            <div class="row mb-3">
                                <div class="col-md-6">
                                    <label class="form-label fw-bold">Chức vụ</label>
                                    <input class="form-control" name="ChucVu" />
                                </div>

                                <div class="col-md-6">
                                    <label class="form-label fw-bold">Ngày vào làm</label>
                                    <input type="date" class="form-control" name="NgayVaoLam" />
                                </div>
                            </div>

                            <div class="mb-3">
                                <label class="form-label fw-bold">Mức lương</label>
                                <input type="number" class="form-control" name="MucLuong" min="0" />
                            </div>

                            <div class="mb-3">
                                <label class="form-label fw-bold">Ghi chú</label>
                                <textarea class="form-control" name="GhiChu"></textarea>
                            </div>

                            <input type="hidden" name="HinhAnh" id="HiddenImage" />

                        </form>
                    </div>
                </div>

            </div>

            <div class="modal-footer">
                <button class="btn btn-primary" onclick="submitAddNV()">
                    <i class="fa-solid fa-check"></i> Lưu
                </button>
                <button class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
            </div>

        </div>
    </div>
</div>

<script>
    // preview avatar
    document.getElementById("imgInput").onchange = e => {
        const file = e.target.files[0];
        if (!file) return;
        const reader = new FileReader();
        reader.onload = ev => document.getElementById("previewImg").src = ev.target.result;
        reader.readAsDataURL(file);
        document.getElementById("HiddenImage").value = file.name;
    };

    function submitAddNV() {
        const form = document.getElementById("formAddNV");
        const data = new FormData(form);

        fetch("/Admin/NhanVien/Them", {
            method: "POST",
            body: data
        }).then(r => r.json()).then(d => {
            alert(d.message);
            if (d.success) location.reload();
        });
    }
</script>
