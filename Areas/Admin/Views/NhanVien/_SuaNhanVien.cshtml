@model WebQuanLiCuaHangTapHoa.Models.NhanVien

<div class="modal fade" id="modalNV" tabindex="-1">
    <div class="modal-dialog modal-xl modal-dialog-centered">
        <div class="modal-content">

            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title"><i class="fa-solid fa-user-pen me-2"></i>Sửa Nhân Viên</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">

                <div class="row">

                    <!-- AVATAR -->
                    <div class="col-md-4 text-center">
                        <img id="previewImg"
                             src="/Images/Employees/@Model.HinhAnh"
                             onerror="this.src='/Images/Employees/default.png'"
                             class="rounded shadow"
                             style="width:100%; max-width:260px; height:260px; object-fit:cover;" />

                        <div class="mt-3">
                            <label class="btn btn-outline-primary btn-sm">
                                <i class="fa-solid fa-image"></i> Đổi ảnh
                                <input type="file" id="imgInput" class="d-none" accept="image/*" />
                            </label>
                        </div>
                    </div>

                    <!-- FORM -->
                    <div class="col-md-8">

                        <form id="formEditNV">

                            <input type="hidden" name="MaNV" value="@Model.MaNV" />

                            <div class="row mb-3">
                                <div class="col-md-6">
                                    <label class="form-label fw-bold">Tên Nhân Viên</label>
                                    <input class="form-control" name="TenNV" value="@Model.TenNV" />
                                </div>

                                <div class="col-md-6">
                                    <label class="form-label fw-bold">Số Điện Thoại</label>
                                    <input class="form-control" name="SoDT" value="@Model.SoDT" />
                                </div>
                            </div>

                            <div class="mb-3">
                                <label class="form-label fw-bold">Email</label>
                                <input class="form-control" name="Email" value="@Model.Email" />
                            </div>

                            <div class="row mb-3">
                                <div class="col-md-6">
                                    <label class="form-label fw-bold">Giới tính</label>
                                    <select class="form-select" name="GioiTinh">
                                        <option value="">— Chọn —</option>
                                        <option value="Nam" @(Model.GioiTinh == "Nam" ? "selected" : "")>Nam</option>
                                        <option value="Nữ" @(Model.GioiTinh == "Nữ" ? "selected" : "")>Nữ</option>
                                        <option value="Khác" @(Model.GioiTinh == "Khác" ? "selected" : "")>Khác</option>
                                    </select>
                                </div>

                                <div class="col-md-6">
                                    <label class="form-label fw-bold">Ngày sinh</label>
                                    <input type="date" class="form-control"
                                           name="NgaySinh"
                                           value="@(Model.NgaySinh?.ToString("yyyy-MM-dd"))" />
                                </div>
                            </div>

                            <div class="mb-3">
                                <label class="form-label fw-bold">Địa chỉ</label>
                                <input class="form-control" name="DiaChi" value="@Model.DiaChi" />
                            </div>

                            <div class="mb-3">
                                <label class="form-label fw-bold">CCCD / CMND</label>
                                <input class="form-control" name="CCCD" value="@Model.CCCD" />
                            </div>

                            <div class="row mb-3">
                                <div class="col-md-6">
                                    <label class="form-label fw-bold">Chức vụ</label>
                                    <input class="form-control" name="ChucVu" value="@Model.ChucVu" />
                                </div>

                                <div class="col-md-6">
                                    <label class="form-label fw-bold">Ngày vào làm</label>
                                    <input type="date" class="form-control"
                                           name="NgayVaoLam"
                                           value="@(Model.NgayVaoLam?.ToString("yyyy-MM-dd"))" />
                                </div>
                            </div>

                            <div class="mb-3">
                                <label class="form-label fw-bold">Mức lương</label>
                                <input type="number" class="form-control" name="MucLuong" value="@Model.MucLuong" />
                            </div>

                            <div class="mb-3">
                                <label class="form-label fw-bold">Ghi chú</label>
                                <textarea class="form-control" name="GhiChu">@Model.GhiChu</textarea>
                            </div>

                            <input type="hidden" id="HiddenImage" name="HinhAnh" value="@Model.HinhAnh" />

                        </form>

                    </div>
                </div>

            </div>

            <div class="modal-footer">
                <button class="btn btn-primary" onclick="submitEditNV()">
                    <i class="fa-solid fa-save"></i> Lưu thay đổi
                </button>
                <button class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
            </div>

        </div>
    </div>
</div>

<script>
    // preview on edit
    document.getElementById("imgInput").onchange = e => {
        const file = e.target.files[0];
        if (!file) return;

        const reader = new FileReader();
        reader.onload = ev => document.getElementById("previewImg").src = ev.target.result;
        reader.readAsDataURL(file);

        document.getElementById("HiddenImage").value = file.name;
    };

    function submitEditNV() {
        const form = new FormData(document.getElementById("formEditNV"));

        fetch("/Admin/NhanVien/Sua", {
            method: "POST",
            body: form
        }).then(r => r.json()).then(d => {
            alert(d.message);
            if (d.success) location.reload();
        });
    }
</script>
