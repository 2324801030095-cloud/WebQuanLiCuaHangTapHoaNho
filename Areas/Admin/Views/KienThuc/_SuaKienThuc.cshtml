@model WebQuanLiCuaHangTapHoa.Models.KienThuc

<div class="modal fade" id="modalKT" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title"><i class="fa-solid fa-pen"></i> Sửa bài viết kiến thức</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            @using (Html.BeginForm("Sua", "KienThuc", FormMethod.Post, new { id = "formKT" }))
            {
                @Html.HiddenFor(m => m.MaKT)
                <div class="modal-body">
                    <div class="mb-3">
                        @Html.LabelFor(m => m.TieuDe, "Tiêu đề *")
                        @Html.TextBoxFor(m => m.TieuDe, new { @class = "form-control", required = "required" })
                    </div>
                    <div class="mb-3">
                        @Html.LabelFor(m => m.Slug, "Slug (URL)")
                        @Html.TextBoxFor(m => m.Slug, new { @class = "form-control" })
                    </div>
                    <div class="mb-3">
                        @Html.LabelFor(m => m.NoiDung, "Nội dung *")
                        @Html.TextAreaFor(m => m.NoiDung, new { @class = "form-control", rows = "10", required = "required" })
                    </div>
                    <div class="form-check">
                        @Html.CheckBoxFor(m => m.TrangThai, new { @class = "form-check-input" })
                        <label class="form-check-label" for="TrangThai">Xuất bản</label>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Đóng</button>
                    <button type="submit" class="btn btn-primary">Cập nhật</button>
                </div>
            }
        </div>
    </div>
</div>

<script>
    document.getElementById("formKT").addEventListener("submit", function(e) {
        e.preventDefault();
        const formData = new FormData(this);
        const obj = {};
        formData.forEach((v, k) => obj[k] = v);
        obj.TrangThai = document.querySelector("[name='TrangThai']").checked;

        fetch("/Admin/KienThuc/Sua", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify(obj)
        })
        .then(r => r.json())
        .then(d => {
            alert(d.message);
            if (d.success) {
                bootstrap.Modal.getInstance(document.getElementById("modalKT")).hide();
                location.reload();
            }
        });
    });
</script>

