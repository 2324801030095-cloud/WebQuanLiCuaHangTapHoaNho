@model PagedList.IPagedList<WebQuanLiCuaHangTapHoa.Models.KienThuc>
@using PagedList.Mvc;

@{
    ViewBag.Title = "Quản lý kiến thức";
    Layout = "~/Areas/Admin/Views/Shared/_LayoutAdmin.cshtml";
}

<div class="container-fluid p-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h4 class="page-title">
            <i class="fa-solid fa-lightbulb"></i>
            Quản lý bài viết kiến thức
        </h4>
        <button class="btn btn-success btn-sm" onclick="them()">
            <i class="fa-solid fa-plus"></i> Thêm bài viết
        </button>
    </div>

    <!-- Filter -->
    <form method="get" class="filter-bar bg-white p-3 rounded shadow-sm mb-3">
        <div class="d-flex gap-2 flex-wrap">
            <input type="text" name="search" value="@ViewBag.Search" placeholder="Tìm kiếm..." class="form-control" style="width:250px;">
            <select name="trangThai" class="form-select" style="width:180px;">
                <option value="">Tất cả</option>
                <option value="true" @(ViewBag.TrangThai == true ? "selected" : "")>Đã xuất bản</option>
                <option value="false" @(ViewBag.TrangThai == false ? "selected" : "")>Nháp</option>
            </select>
            <button type="submit" class="btn btn-primary"><i class="fa-solid fa-filter"></i> Lọc</button>
            <a href="@Url.Action("Index")" class="btn btn-secondary"><i class="fa-solid fa-rotate-right"></i> Làm mới</a>
        </div>
    </form>

    <!-- Table -->
    <div class="card shadow-sm">
        <div class="table-responsive">
            <table class="table table-bordered mb-0">
                <thead>
                    <tr>
                        <th>Mã</th>
                        <th>Tiêu đề</th>
                        <th>Slug</th>
                        <th>Lượt xem</th>
                        <th>Ngày đăng</th>
                        <th>Trạng thái</th>
                        <th>Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Count == 0)
                    {
                        <tr>
                            <td colspan="7" class="text-center text-muted py-4">Không có bài viết nào.</td>
                        </tr>
                    }
                    else
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.MaKT</td>
                                <td>@item.TieuDe</td>
                                <td>@item.Slug</td>
                                <td>@item.LuotXem</td>
                                <td>@(item.NgayDang.HasValue ? item.NgayDang.Value.ToString("dd/MM/yyyy") : "")</td>
                                <td>
                                    @if (item.TrangThai)
                                    {
                                        <span class="badge bg-success">Xuất bản</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Nháp</span>
                                    }
                                </td>
                                <td>
                                    <button class="btn btn-primary btn-sm" onclick="sua(@item.MaKT)" title="Sửa">
                                        <i class="fa-solid fa-pen"></i>
                                    </button>
                                    <button class="btn btn-danger btn-sm" onclick="xoa(@item.MaKT)" title="Xóa">
                                        <i class="fa-solid fa-trash"></i>
                                    </button>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>

        <div class="card-footer bg-white text-center">
            @Html.PagedListPager(Model, page => Url.Action("Index", new { page, search = ViewBag.Search, trangThai = ViewBag.TrangThai }),
            new PagedListRenderOptions
            {
                Display = PagedListDisplayMode.IfNeeded,
                DisplayLinkToFirstPage = PagedListDisplayMode.Always,
                DisplayLinkToLastPage = PagedListDisplayMode.Always,
                DisplayLinkToPreviousPage = PagedListDisplayMode.Always,
                DisplayLinkToNextPage = PagedListDisplayMode.Always,
                DisplayEllipsesWhenNotShowingAllPageNumbers = true,
                MaximumPageNumbersToDisplay = 5,
                UlElementClasses = new[] { "pagination" }
            })
        </div>
    </div>
</div>

<div id="modalContainer"></div>

<script>
    function them() {
        fetch("/Admin/KienThuc/Them")
            .then(r => r.text())
            .then(html => {
                const modalContainer = document.getElementById("modalContainer");
                if (window.renderHtml) {
                    window.renderHtml(modalContainer, html);
                } else {
                    modalContainer.innerHTML = html;
                }
                new bootstrap.Modal(document.getElementById("modalKT")).show();
            });
    }

    function sua(id) {
        fetch(`/Admin/KienThuc/Sua/${id}`)
            .then(r => r.text())
            .then(html => {
                const modalContainer = document.getElementById("modalContainer");
                if (window.renderHtml) {
                    window.renderHtml(modalContainer, html);
                } else {
                    modalContainer.innerHTML = html;
                }
                new bootstrap.Modal(document.getElementById("modalKT")).show();
            });
    }

    function xoa(id) {
        if (!confirm("Xóa bài viết này?")) return;
        fetch("/Admin/KienThuc/Xoa", {
            method: "POST",
            headers: { "Content-Type": "application/x-www-form-urlencoded" },
            body: `id=${id}`
        })
        .then(r => r.json())
        .then(d => {
            alert(d.message);
            if (d.success) location.reload();
        });
    }
</script>

