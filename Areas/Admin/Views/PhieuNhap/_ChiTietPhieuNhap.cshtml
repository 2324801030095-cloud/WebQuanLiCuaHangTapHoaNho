@model IEnumerable<WebQuanLiCuaHangTapHoa.Areas.Admin.Models.ViewModels.ChiTietPN_VM>

@{
    Layout = null;

    var phieu = ViewBag.Phieu as WebQuanLiCuaHangTapHoa.Models.PhieuNhap;
    var tong = ViewBag.TongTien ?? 0;
}

<style>
    :root {
        --main: #2563eb;
        --main-light: #3b82f6;
        --bg-soft: #f1f5f9;
        --border: #e2e8f0;
        --text-dark: #1e293b;
    }

    .modal-content {
        border-radius: 18px;
        box-shadow: 0 8px 30px rgba(0,0,0,0.15);
        animation: fadeIn .25s ease;
    }

    @@keyframes fadeIn {
        from { opacity: 0; transform: translateY(10px); }
        to { opacity: 1; transform: translateY(0); }
    }

    .modal-header {
        background: linear-gradient(90deg, var(--main), var(--main-light));
        color: white;
        padding: 18px 24px;
    }

    .modal-title {
        font-size: 20px;
        font-weight: 600;
        text-shadow: 0 1px 2px rgba(0,0,0,0.25);
    }

    /* Info section (nâng cấp như card) */
    .info-box {
        background: white;
        border-radius: 14px;
        padding: 16px 18px;
        border: 1px solid var(--border);
        margin-bottom: 18px;
        box-shadow: 0 3px 12px rgba(0,0,0,0.06);
        font-size: 15px;
        line-height: 1.7;
    }

        .info-box strong {
            color: var(--main);
            font-weight: 600;
        }

    /* Bảng */
    table thead th {
        background: var(--bg-soft);
        border-bottom: 2px solid var(--border);
        padding: 12px;
        font-weight: 700;
        color: var(--text-dark);
    }

    table tbody td {
        padding: 12px;
        vertical-align: middle;
        font-size: 15px;
    }

    tbody tr {
        transition: background .2s;
    }

    tbody tr:hover {
        background: #ecf3ff;
    }

    /* Tổng tiền box */
    .total-box {
        background: white;
        padding: 12px 22px;
        border-radius: 12px;
        display: inline-block;
        border: 1px solid var(--border);
        box-shadow: 0 4px 15px rgba(37,99,235,0.12);
        color: var(--main);
        font-weight: 700;
        font-size: 17px;
    }

    /* Footer */
    .modal-footer {
        background: var(--bg-soft);
        border-top: 1px solid var(--border);
        border-radius: 0 0 18px 18px;
        padding: 14px 20px;
    }
</style>

<div class="modal fade" id="modalCTPN">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">

            <!-- HEADER -->
            <div class="modal-header">
                <h5 class="modal-title">
                    <i class="fa-solid fa-receipt me-2"></i>
                    Chi tiết phiếu nhập – @(phieu != null ? phieu.MaPN.ToString() : "")
                </h5>
                <button class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>

            <!-- BODY -->
            <div class="modal-body">

                <!-- Info block (như card) -->
                <div class="info-box">
                    <div><strong>Nhà cung cấp:</strong> @(phieu?.NhaCungCap?.TenNCC ?? "")</div>
                    <div><strong>Nhân viên:</strong> @(phieu?.NhanVien?.TenNV ?? "")</div>
                    <div><strong>Ngày nhập:</strong> @(phieu != null ? phieu.Ngay.ToString("dd/MM/yyyy HH:mm") : "")</div>
                </div>

                <!-- Table -->
                <table class="table table-bordered table-hover">
                    <thead>
                        <tr>
                            <th style="width:40%">Sản phẩm</th>
                            <th style="width:10%">SL</th>
                            <th style="width:20%">Đơn giá</th>
                            <th style="width:20%">Thành tiền</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var ct in Model)
                        {
                            <tr>
                                <td>@ct.TenSP</td>
                                <td class="text-center">@ct.SoLuong</td>
                                <td class="text-end">@String.Format("{0:N0}", ct.DonGia)</td>
                                <td class="text-end fw-bold">@String.Format("{0:N0}", ct.ThanhTien)</td>
                            </tr>
                        }
                    </tbody>
                </table>

                <!-- Total -->
                <div class="text-end mt-2">
                    <div class="total-box">
                        Tổng cộng: @String.Format("{0:N0}", tong) ₫
                    </div>
                </div>

            </div>

            <!-- FOOTER -->
            <div class="modal-footer">
                <button class="btn btn-secondary px-4" data-bs-dismiss="modal">
                    Đóng
                </button>
            </div>

        </div>
    </div>
</div>
