@model PagedList.IPagedList<WebQuanLiCuaHangTapHoa.Models.PhieuNhap>
@using PagedList.Mvc

@{
    Layout = "~/Areas/Admin/Views/Shared/_LayoutAdmin.cshtml";
}

<!-- ===================== Toastr + SweetAlert ===================== -->
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css" />
<script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<style>

    /* ===== TIÊU ĐỀ TRANG (CHẾ ĐỘ SÁNG) ===== */
    .page-title {
        color: #2563eb; /* xanh primary */
        font-size: 1.8rem;
    }

    .page-title-icon {
        color: #0ea5e9; /* xanh icon */
        font-size: 1.6rem;
        transition: .25s ease;
    }

    /* ===== DARK MODE NEON GLOW ===== */
    body.dark .page-title {
        color: transparent !important;
        background: linear-gradient(90deg, #93c5fd, #34d399, #a78bfa);
        -webkit-background-clip: text;
        text-shadow: 0 0 6px rgba(255,255,255,0.35), 0 0 10px rgba(147,197,253,0.5);
    }

    body.dark .page-title-icon {
        background: linear-gradient(90deg, #60a5fa, #34d399);
        -webkit-background-clip: text;
        color: transparent;
        text-shadow: 0 0 6px rgba(147,197,253,0.7), 0 0 12px rgba(34,197,94,0.7), 0 0 20px rgba(147,197,253,0.4);
        transition: .25s ease;
    }

        body.dark .page-title-icon:hover {
            transform: scale(1.12);
            text-shadow: 0 0 12px rgba(147,197,253,0.9), 0 0 20px rgba(34,197,94,0.9), 0 0 30px rgba(147,197,253,0.7);
        }
    th, td {
        text-align: center;
        vertical-align: middle;
    }

    table {
        width: 100%;
    }

    td button, td .btn, td .btn-action {
        white-space: nowrap !important;
    }

    /* =============== PHÂN TRANG CŨ =============== */
    .pagination {
        display: flex;
        justify-content: center;
        margin: 20px 0;
        flex-wrap: wrap;
        gap: 6px;
    }

        .pagination li {
            list-style: none;
        }

            .pagination li a, .pagination li span {
                display: block;
                padding: 8px 12px;
                border-radius: 8px;
                color: #1e293b;
                border: 1px solid #e2e8f0;
                background: #f8fafc;
                text-decoration: none;
                font-weight: 500;
                transition: all 0.25s ease;
            }

                .pagination li a:hover {
                    background: #e0f2fe;
                    color: #1d4ed8;
                    transform: translateY(-2px);
                    box-shadow: 0 2px 5px rgba(37,99,235,0.2);
                }

            .pagination li.active a {
                background: linear-gradient(90deg, #2563eb, #3b82f6);
                color: white !important;
                border-color: #2563eb;
                box-shadow: 0 2px 8px rgba(37,99,235,0.35);
            }

            .pagination li.disabled a {
                opacity: 0.5;
                pointer-events: none;
            }

    /* =============== SKELETON LOADING =============== */
    .skeleton {
        height: 16px;
        background: linear-gradient(90deg,#e2e8f0,#f8fafc,#e2e8f0);
        border-radius: 6px;
        animation: skeleton 1.4s infinite ease-in-out;
    }

    @@keyframes skeleton {
        0% {
            opacity: .4;
        }

        50% {
            opacity: 1;
        }

        100% {
            opacity: .4;
        }
    }

    /* =============== OVERLAY =============== */
    #loadingOverlay {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(255,255,255,.75);
        backdrop-filter: blur(6px);
        display: none;
        align-items: center;
        justify-content: center;
        z-index: 2500;
    }

    .spinner-border {
        width: 3rem;
        height: 3rem;
        color: #2563eb;
    }

    /* Hiệu ứng fade-in bảng */
    #tableContainer {
        opacity: 0;
        transform: translateY(6px);
        transition: all .45s ease;
    }

        #tableContainer.show {
            opacity: 1;
            transform: translateY(0);
        }
</style>

<!-- ===================== Overlay ===================== -->
<div id="loadingOverlay">
    <div class="spinner-border"></div>
</div>

<div class="container-fluid p-4 pt-2">
    <div class="text-center mb-3">
        <h4 class="page-title fw-bold d-inline-flex align-items-center gap-2 m-0">
            <i class="fa-solid fa-truck"></i>
            Trang Quản Lý Phiếu Nhập
        </h4>
    </div>


    <div class="text-end mb-3">
        <button class="btn btn-success btn-sm" id="btnAdd">
            <i class="fa-solid fa-plus"></i> Thêm phiếu nhập
        </button>
    </div>

    <!-- ===================== SKELETON ===================== -->
    <div id="skeletonTable" class="mt-3">
        @for (int i = 0; i < 6; i++)
        {
            <div class="row" style="display:grid; grid-template-columns:90px 160px 260px 200px 170px; gap:8px; padding:12px;">
                @for (int j = 0; j < 5; j++)
                {
                    <div class="skeleton"></div>
                }
            </div>
        }
    </div>

    <div class="card shadow-sm mt-3" id="realTable" style="display:none;">
        <div id="tableContainer">

            <table class="table table-bordered table-hover mb-0">
                <thead class="table-light text-center">
                    <tr>
                        <th style="width: 90px;">Mã PN</th>
                        <th style="width: 160px;">Ngày nhập</th>
                        <th style="width: 260px;">Nhà cung cấp</th>
                        <th style="width: 200px;">Nhân viên</th>
                        <th style="width: 170px;">Thao tác</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var pn in Model)
                    {
                        <tr>
                            <td>@pn.MaPN</td>
                            <td>@pn.Ngay.ToString("dd/MM/yyyy HH:mm")</td>
                            <td>@(pn.NhaCungCap != null ? pn.NhaCungCap.TenNCC : "-")</td>
                            <td>@(pn.NhanVien != null ? pn.NhanVien.TenNV : "-")</td>

                            <td>
                                <button class="btn btn-info btn-sm me-1 btnView text-white" data-id="@pn.MaPN">
                                    <i class="fa-solid fa-eye"></i>
                                </button>

                                <button class="btn btn-primary btn-sm me-1 btnEdit" data-id="@pn.MaPN">
                                    <i class="fa-solid fa-pen-to-square"></i>
                                </button>

                                <button class="btn btn-danger btn-sm btnDelete" data-id="@pn.MaPN">
                                    <i class="fa-solid fa-trash-can"></i>
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>

            <div class="card-footer bg-white text-center">
                @Html.PagedListPager(
                    Model,
                    page => Url.Action("Index", new
                    {
                        page,
                        search = Request["search"],
                        from = Request["from"],
                        to = Request["to"]
                    }),
                    new PagedListRenderOptions
                    {
                        UlElementClasses = new[] { "pagination" },
                        MaximumPageNumbersToDisplay = 5,
                        DisplayLinkToPreviousPage = PagedListDisplayMode.Always,
                        DisplayLinkToNextPage = PagedListDisplayMode.Always,
                        DisplayLinkToFirstPage = PagedListDisplayMode.Always,
                        DisplayLinkToLastPage = PagedListDisplayMode.Always
                    })
            </div>

        </div>
    </div>
</div>

<div id="modalArea"></div>

<script>
    // ===================== LOADING =====================
    function showLoading() { loadingOverlay.style.display = "flex"; }
    function hideLoading() { loadingOverlay.style.display = "none"; }

    // ===================== SKELETON =====================
    window.onload = () => {
        setTimeout(() => {
            skeletonTable.style.display = "none";
            realTable.style.display = "block";
            tableContainer.classList.add("show");
        }, 350);
    };

    // ===================== MODAL LOAD =====================
    function loadModal(url, id) {
        showLoading();
        fetch(url)
            .then(res => res.text())
            .then(html => {
                modalArea.innerHTML = html;
                hideLoading();
                new bootstrap.Modal(document.getElementById(id)).show();
            })
            .catch(() => {
                hideLoading();
                toastr.error("Không thể tải dữ liệu");
            });
    }

    // ===================== ADD =====================
    btnAdd.onclick = () =>
        loadModal('/Admin/PhieuNhap/Them', 'modalThemPN');

    // ===================== CLICK ACTIONS =====================
    document.addEventListener("click", e => {
        const btn = e.target.closest("button");
        if (!btn) return;

        if (btn.classList.contains("btnView"))
            return loadModal(`/Admin/PhieuNhap/ChiTiet/${btn.dataset.id}`, "modalCTPN");

        if (btn.classList.contains("btnEdit"))
            return loadModal(`/Admin/PhieuNhap/Sua/${btn.dataset.id}`, "modalSuaPN");

        if (btn.classList.contains("btnDelete")) {

            Swal.fire({
                title: "Xóa phiếu nhập?",
                text: "Bạn không thể hoàn tác!",
                icon: "warning",
                showCancelButton: true,
                confirmButtonText: "Xóa",
                cancelButtonText: "Hủy",
            }).then(result => {
                if (!result.isConfirmed) return;

                showLoading();

                fetch('/Admin/PhieuNhap/Xoa', {
                    method: "POST",
                    headers: { "Content-Type": "application/json" },
                    body: JSON.stringify({ id: btn.dataset.id })
                })
                    .then(r => r.json())
                    .then(data => {
                        hideLoading();

                        if (data.success) {
                            toastr.success(data.message);
                            setTimeout(() => location.reload(), 500);
                        }
                        else {
                            toastr.error(data.message);
                        }
                    })
                    .catch(() => {
                        hideLoading();
                        toastr.error("Lỗi khi kết nối server");
                    });
            });
        }
    });
</script>
