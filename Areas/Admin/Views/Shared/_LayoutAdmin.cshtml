@{
    Layout = null;
    var userName = Session["UserName"] ?? "Admin";
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Quản trị cửa hàng tạp hóa</title>

    <!-- Bootstrap & FontAwesome -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />

    <style>
        /* ====================== BASE (GIỮ NGUYÊN) + TÙY CHỈNH THU GỌN ====================== */
        :root {
            --bg: #f3f6fb;
            --surface: #ffffff;
            --surface-2: #f8fafc;
            --border: #e5e7eb;
            --text: #0f172a;
            --muted: #64748b;
            --accent: #2563eb;
            --accent-2: #3b82f6;
            --success: #16a34a;
            --danger: #ef4444;
        }

        body {
            background-color: var(--bg);
            font-family: 'Inter', 'Segoe UI', system-ui, -apple-system, sans-serif;
            color: var(--text);
            transition: all 0.3s ease;
            -webkit-font-smoothing: antialiased;
            -moz-osx-font-smoothing: grayscale;
        }
        
        * {
            font-family: 'Inter', 'Segoe UI', system-ui, -apple-system, sans-serif;
        }

        /* ===== Sidebar ===== */
        .sidebar {
            position: fixed;
            top: 0;
            left: 0;
            height: 100vh;
            width: 200px;
            background: linear-gradient(180deg, #1e293b 0%, #0f172a 100%);
            color: #e2e8f0;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            transition: all 0.2s ease;
            z-index: 1000;
            padding-top: 12px;
            box-shadow: 0 4px 18px rgba(2,6,23,0.08);
        }

        .sidebar.collapsed {
            width: 80px;
        }

        /* Remove large sidebar-user, we place avatar in header */
        .sidebar-user { display: none; }

        .sidebar h4 {
            text-align: center;
            font-size: 18px;
            margin: 8px 0;
            font-weight: 600;
            color: #e6eefb;
        }

        .sidebar a {
            display: flex;
            align-items: center;
            padding: 10px 18px !important; /* thu nhỏ padding */
            text-decoration: none;
            color: #cbd5e1;
            transition: all 0.20s;
            border-left: 4px solid transparent;
            font-size: 14px !important; /* thu nhỏ chữ menu */
            gap: 12px;
        }

        .sidebar a i {
            margin-right: 8px;
            width: 20px;
            text-align: center;
            font-size: 16px !important;
        }

        .sidebar a:hover {
            background-color: rgba(255,255,255,0.06);
            border-left: 4px solid #3b82f6;
            color: #ffffff;
        }

        /* Sidebar menu scroll region */
        .sidebar-menu {
            flex: 1;
            overflow-y: auto;
            padding-bottom: 10px;
            margin-top: 6px;
        }

        .sidebar-menu::-webkit-scrollbar { width:6px; }
        .sidebar-menu::-webkit-scrollbar-thumb {
            background: rgba(255,255,255,0.12);
            border-radius: 10px;
        }

        /* Sticky logout at bottom */
        .sidebar-bottom {
            position: sticky;
            bottom: 0;
            padding: 10px;
            border-top: 1px solid rgba(255,255,255,0.06);
            background: transparent;
        }

        .logout-btn {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            width: 100%;
            text-align: center;
            background: #ef4444;
            color: white;
            font-weight: 600;
            border-radius: 8px;
            padding: 8px 0;
            text-decoration: none;
            transition: transform .18s ease, background .18s ease;
            font-size: 14px;
        }

        .logout-btn i { font-size: 16px; }
        .logout-btn:hover { background: #dc2626; transform: translateY(-1px); }

        .sidebar.collapsed .logout-btn span { display: none; }
        .sidebar.collapsed .logout-btn { padding: 10px 0; }

        /* ====================== Header Bar (compact) ====================== */
        .header-bar {
            position: fixed;
            top: 0;
            left: 200px;
            width: calc(100% - 200px);
            padding: 8px 18px; /* giảm padding cho header nhỏ gọn */
            display: flex;
            align-items: center;
            justify-content: space-between;
            background: rgba(255,255,255,0.85);
            backdrop-filter: blur(10px);
            -webkit-backdrop-filter: blur(10px);
            border-bottom: 1px solid rgba(0,0,0,0.06);
            box-shadow: 0 6px 18px rgba(2,6,23,0.04);
            border-radius: 0 0 12px 12px;
            transition: all 0.25s ease;
            z-index: 999;
            height: 56px;
        }

        .header-bar .left-group { display:flex; align-items:center; gap:10px; }
        .header-bar .right-group { display:flex; align-items:center; gap:12px; }

        .toggle-btn {
            background: none;
            border: none;
            color: #1e293b;
            font-size: 26px;
            cursor: pointer;
            padding:12px 16px;
            width: 56px;
            height: 56px;
            border-radius: 12px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            margin-left: -6px;
        }

        .header-bar h5 {
            margin:0;
            font-size:15px;
            color: #0f172a;
        }

        /* Avatar nhỏ trong header */
        .user-mini-avatar {
            width: 32px;
            height: 32px;
            border-radius: 50%;
            object-fit: cover;
            border: 2px solid #3b82f6;
            transition: .20s;
        }
        .user-mini-avatar:hover { transform: scale(1.06); }

        /* Dribbble-style switch smaller */
        .dribbble-switch {
            --w: 72px;
            --h: 32px;
            position: relative;
            width: var(--w);
            height: var(--h);
            border-radius: 50px;
            cursor: pointer;
            user-select: none;
            padding: 4px;
            display: inline-flex;
            align-items: center;
            transition: 0.25s ease;
        }
        .dribbble-switch .track {
            position:absolute; inset:0; border-radius:50px;
            background: linear-gradient(145deg, #ffffff, #e6eefb);
            box-shadow: inset 1px 1px 6px rgba(0,0,0,0.06);
            z-index:1;
        }
        .dribbble-switch .icons { position:absolute; inset:0 12px; display:flex; justify-content:space-between; align-items:center; font-size:12px; color:#6b7280; z-index:3; pointer-events:none; }
        .dribbble-switch .knob {
            position:absolute; width: calc(var(--h) - 8px); height: calc(var(--h) - 8px); border-radius:50%;
            left:4px; display:flex; align-items:center; justify-content:center; font-size:13px;
            background: radial-gradient(circle at 30% 30%, #ffffff, #eef3fb 60%);
            box-shadow: 0 2px 8px rgba(0,0,0,0.12);
            transition: .32s cubic-bezier(.25,.8,.25,1);
            z-index:4;
        }
        .dribbble-switch[data-mode="dark"] .knob { transform: translateX(calc(var(--w) - var(--h))); filter: drop-shadow(0 0 14px rgba(110,130,255,0.9)); }

        /* ====================== Sidebar Hover / Ripple / Active (retain effects) ====================== */

        .sidebar-menu a { position: relative; overflow: hidden; z-index:1; }
        .sidebar-menu a::before {
            content: ""; position:absolute; top:0; left:-100%; width:100%; height:100%;
            background: linear-gradient(90deg, rgba(59,130,246,0.18), rgba(37,99,235,0.22));
            transition: all .30s ease; z-index:-1; border-radius:6px;
        }
        .sidebar-menu a:hover::before { left:0; }

        .sidebar-menu a:hover i { filter: drop-shadow(0 0 6px rgba(96,165,250,0.6)); transition: .20s; }
        .sidebar-menu a:hover span { color: #fff; }

        /* Active state - neon green border (kept) */
        .sidebar-menu a.active {
            color: #ffffff;
            font-weight: 600;
            border-left: 4px solid #3b82f6;
            background: linear-gradient(90deg, rgba(59,130,246,0.12), rgba(37,99,235,0.08));
            box-shadow: inset 0 0 12px rgba(37,99,235,0.08);
        }
        .sidebar-menu a.active i {
            color: #3b82f6;
            transform: scale(1.10);
            filter: drop-shadow(0 0 5px rgba(96,165,250,0.6));
        }

        /* Ripple effect */
        .sidebar-menu a::after {
            content: "";
            position: absolute;
            width: 10px; height: 10px;
            background: rgba(255,255,255,0.4);
            opacity: 0;
            border-radius: 50%;
            transform: scale(1);
            transition: transform .45s ease, opacity .45s ease;
            pointer-events: none;
        }
        .sidebar-menu a.ripple::after { opacity: 1; transform: scale(25); transition: none; }

        /* Hover behavior when collapsed */
        .sidebar.collapsed .sidebar-menu a { justify-content:center; padding: 12px 0 !important; }
        .sidebar.collapsed .sidebar-menu a span {
            position:absolute; left:100%; top:50%; transform: translateY(-50%);
            background: #0f172a; padding:6px 10px; border-radius:6px; white-space:nowrap;
            opacity:0; pointer-events:none; margin-left: 10px; transition: .20s;
            box-shadow: 0 6px 18px rgba(2,6,23,0.28); color:#fff;
        }
        .sidebar.collapsed .sidebar-menu a:hover span { opacity:1; transform: translateY(-50%) translateX(6px); }

        /* Prevent translateX in collapsed hover (fix jitter) */
        .sidebar.collapsed .sidebar-menu a:hover { transform: none !important; }
        .sidebar { transition: none !important; }

        /* ====================== Content area ====================== */
        .content {
            margin-left: 200px;
            padding: 60px 30px 40px;
            transition: all .25s ease;
        }
        .collapsed ~ .content, .sidebar.collapsed ~ .content {
            margin-left: 80px;
        }

        footer { text-align: center; color: #6b7280; font-size: 14px; margin-top: 28px; }

        /* ====================== Dark mode adjustments (kept) ====================== */
        body.dark {
            --bg: #0b1220;
            --surface: #0f172a;
            --surface-2: #0b1528;
            --border: #1f2a44;
            --text: #e2e8f0;
            --muted: #94a3b8;
            background-color: var(--bg);
            color: var(--text);
        }
        body.dark .header-bar { background: rgba(15,23,42,0.82); border-bottom-color: rgba(255,255,255,0.06); }
        body.dark .sidebar { background: linear-gradient(180deg,#0f172a 0%, #020617 100%); }
        body.dark .content { color: var(--text); }
        body.dark .user-greeting-name { color: #e2e8f0 !important; }
        body.dark .stat-card,
        body.dark .kpi-box {
            color: #e2e8f0 !important;
        }

        body.dark .stat-card h4,
        body.dark .stat-card h6,
        body.dark .kpi-box h3,
        body.dark .kpi-box h4,
        body.dark .kpi-box h6 {
            color: #e2e8f0 !important;
        }

        body.dark .stat-card .text-dark,
        body.dark .kpi-box .text-dark,
        body.dark .stat-card .text-secondary,
        body.dark .kpi-box .text-secondary {
            color: #cbd5e1 !important;
        }

        body:not(.dark) .sidebar {
            background: var(--surface) !important;
            border-right: 1px solid #E5E7EB;
            color: #1E293B;
        }
        body:not(.dark) .sidebar-menu a { color:#1E293B !important; }
        body:not(.dark) .sidebar-menu a:hover { background-color: #F3F4F6 !important; border-left:4px solid #22C55E !important; }
        body:not(.dark) .logout-btn { background: #EF4444 !important; color: #fff !important; }

        /* Page title compact */
        .page-title { color:#2563eb; font-size:1.375rem; font-weight:700; margin:0; }

        /* Responsive */
        @@media (max-width: 992px) {
            .sidebar { left:-260px; }
            .sidebar.active { left:0; }
            .header-bar { left:0; width:100%; border-radius:0; }
            .content { margin-left:0; padding-top:80px; }
        }

        /* small helpers */
        .ms-2 { margin-left:.5rem; }

        /* ---------------- FIX HEADER WIDTH WHEN SIDEBAR COLLAPSED ---------------- */
        .header-bar.collapsed {
            left: 80px !important;
            width: calc(100% - 80px) !important;
        }

        .header-bar {
            left: 200px !important;
            width: calc(100% - 200px) !important;
        }
        /* ========================= MENU SIZE UPGRADE ============================= */

        /* Tăng chiều cao item menu */
        .sidebar a {
            padding: 14px 20px !important;
            font-size: 15.5px !important;
        }

            /* Icon lớn hơn */
            .sidebar a i {
                font-size: 20px !important;
                width: 26px;
            }

        /* ========================= Ô ĐẶC BIỆT (HOME BOX) ========================= */

        .sidebar-home-box {
            width: 100%;
            height: 110px; /* gấp đôi item menu */
            border-radius: 12px;
            background: linear-gradient(135deg, #3b82f6, #2563eb);
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            margin-bottom: 14px;
            transition: transform .15s ease;
        }

            .sidebar-home-box i {
                font-size: 42px; /* icon lớn */
                color: #fff;
            }

            .sidebar-home-box:hover {
                transform: scale(1.03);
                /* không có hover màu sắc */
            }

        /* Khi sidebar collapsed: box thu nhỏ nhưng icon vẫn đẹp */
        .sidebar.collapsed .sidebar-home-box {
            height: 90px;
        }

            .sidebar.collapsed .sidebar-home-box i {
                font-size: 36px;
            }
        /* Nút HOME nổi bật hơn */
        .sidebar-menu .home-btn {
            color: white !important;
            font-weight: 600;
            border-radius: 10px;
            margin-bottom: 10px;
            padding: 14px 18px;
            display: flex;
            align-items: center;
            gap: 12px;
            transition: 0.25s ease;
            box-shadow: 0 3px 10px rgba(79, 70, 229, 0.5);
        }

            .sidebar-menu .home-btn i {
                font-size: 1.3rem;
            }

            .sidebar-menu .home-btn:hover {
                opacity: 0.9;
                transform: translateY(-2px);
            }

            /* Khi active (đang ở trang Home) */
            .sidebar-menu .home-btn.active {
                box-shadow: 0 0 12px rgba(59, 130, 246, 0.45);
                filter: brightness(1.15);
            }

        /* ====================== UNIFIED TABLE + PAGINATION ====================== */
        .content .card,
        .content .table-container,
        .content .card-pro {
            background: var(--surface) !important;
            border: 1px solid var(--border) !important;
            border-radius: 12px !important;
        }

        .content .table {
            background: var(--surface) !important;
            color: var(--text) !important;
        }

        .content .table thead th {
            background: var(--surface-2) !important;
            color: var(--text) !important;
            border-color: var(--border) !important;
            font-weight: 600 !important;
        }

        .content .table td,
        .content .table th {
            border-color: var(--border) !important;
        }

        .content .pagination {
            display: flex !important;
            justify-content: center !important;
            gap: 6px !important;
            padding: 12px 8px !important;
            flex-wrap: wrap !important;
        }

        .content .pagination li a,
        .content .pagination li span {
            display: block !important;
            padding: 8px 12px !important;
            border-radius: 10px !important;
            background: var(--surface-2) !important;
            border: 1px solid var(--border) !important;
            color: var(--text) !important;
            text-decoration: none !important;
            font-weight: 500 !important;
            transition: all 0.2s ease !important;
        }

        .content .pagination li a:hover {
            background: #e0f2fe !important;
            color: #1d4ed8 !important;
            transform: translateY(-2px) !important;
            box-shadow: 0 2px 6px rgba(37,99,235,0.18) !important;
        }

        .content .pagination li.active a,
        .content .pagination li.active span {
            background: linear-gradient(90deg, #2563eb, #3b82f6) !important;
            color: #ffffff !important;
            border-color: #2563eb !important;
            box-shadow: 0 2px 8px rgba(37,99,235,0.35) !important;
        }

        .content .pagination li.disabled a,
        .content .pagination li.disabled span {
            opacity: 0.5 !important;
            pointer-events: none !important;
        }

        /* ====================== BTN GROUP HOVER FIX ====================== */
        .content .btn-group {
            gap: 6px;
        }

        .content .btn-group > .btn {
            border-radius: 10px !important;
            margin-left: 0 !important;
        }

        .content .btn-group > .btn:hover,
        .content .btn-group > .btn:focus {
            z-index: 1;
        }

        /* ====================== FRIENDLY TOAST ====================== */
        #appToast {
            position: fixed;
            inset: 0;
            display: flex;
            align-items: center;
            justify-content: center;
            z-index: 99999;
            pointer-events: none;
            opacity: 0;
            transition: opacity .2s ease;
        }

        #appToast.show { opacity: 1; }

        .app-toast-card {
            pointer-events: auto;
            display: flex;
            align-items: center;
            gap: 12px;
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: 14px;
            padding: 14px 18px;
            box-shadow: 0 16px 40px rgba(2,6,23,0.18);
            min-width: 320px;
            max-width: 520px;
        }

        .app-toast-icon {
            width: 44px;
            height: 44px;
            border-radius: 12px;
            display: grid;
            place-items: center;
            background: #eff6ff;
            color: #2563eb;
            flex: 0 0 44px;
            font-size: 20px;
        }

        .app-toast-card.success .app-toast-icon { background: #ecfdf3; color: #16a34a; }
        .app-toast-card.error .app-toast-icon { background: #fef2f2; color: #ef4444; }
        .app-toast-card.warning .app-toast-icon { background: #fffbeb; color: #f59e0b; }

        .app-toast-title {
            font-weight: 700;
            color: var(--text);
            margin-bottom: 2px;
        }

        .app-toast-message {
            color: var(--muted);
            font-size: 14px;
        }
    </style>
</head>
<body class="@(Request.Cookies["theme"]?.Value == "dark" ? "dark" : "")">

