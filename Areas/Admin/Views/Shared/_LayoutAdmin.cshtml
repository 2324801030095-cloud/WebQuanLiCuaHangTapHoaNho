                <i class="fa-solid fa-envelope"></i><span>Tin nhắn</span>
            </a>

            <!-- Tài khoản khách hàng -->
            <a href="@Url.Action("Index","TaiKhoanKH", new { area = "Admin" })"
               class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "TaiKhoanKH" ? "active" : "")">
                <i class="fa-solid fa-id-card"></i><span>Tài Khoản KH</span>
            </a>

            <!-- Thông tin cửa hàng -->
            <a href="@Url.Action("ThongTinHeThong","Admin", new { area = "Admin" })"
               class="@(ViewContext.RouteData.Values["action"]?.ToString() == "ThongTinHeThong" ? "active" : "")">
                <i class="fa-solid fa-store"></i><span>Thông tin cửa hàng</span>
            </a>

            <!-- Cài đặt -->
            <a href="@Url.Action("CaiDat","Admin", new { area = "Admin" })"
               class="@(ViewContext.RouteData.Values["action"]?.ToString() == "CaiDat" ? "active" : "")">
                <i class="fa-solid fa-gear"></i><span>Cài đặt</span>
            </a>




        </div>

        <!-- Nút logout luôn ghim dưới cùng -->
        <div class="sidebar-bottom">
            <a href="@Url.Action("Logout", "AdminAuth", new { area = "Admin" })" class="logout-btn" title="Đăng xuất">
                <i class="fa-solid fa-right-from-bracket"></i>
                <span>Đăng xuất</span>
            </a>
        </div>

    </div>

    <!-- ===== Header ===== -->
    <div class="header-bar show d-flex align-items-center justify-content-between">

        <div class="left-group d-flex align-items-center">
            <!-- Toggle Sidebar -->
            <button id="toggleBtn" class="toggle-btn" aria-label="Toggle sidebar">
                <i class="fa-solid fa-bars"></i>
            </button>

           
        </div>

        <div class="right-group d-flex align-items-center">
            <!-- Theme switch -->
            <div id="themeSwitch" class="dribbble-switch" data-mode="light" role="button" aria-label="Theme switch">
                <div class="track"></div>
                <div class="icons">
                    <i class="fa-solid fa-sun"></i>
                    <i class="fa-solid fa-moon"></i>
                </div>
                <div class="knob"><i class="fa-solid fa-sun"></i></div>
            </div>

            <!-- Greeting -->
            <h5 class="m-0 fw-semibold text-primary d-none d-sm-inline-flex align-items-center">
                <i class="fa-solid fa-hand-peace me-2 text-warning"></i>
                Xin chào, <span class="text-dark ms-1 user-greeting-name">@userName</span>
            </h5>

            <!-- Avatar small (on the right) -->
            <div class="ms-3">
                <img src="https://cdn-icons-png.flaticon.com/512/149/149071.png" class="user-mini-avatar" alt="User" />
            </div>
        </div>
    </div>

    <!-- ===== Main Content ===== -->
    <div class="content">
        @RenderBody()
        <footer>
            © @DateTime.Now.Year - Hệ thống quản lý cửa hàng tạp hóa |
            <span class="text-primary fw-semibold">Apollo Dev</span>
        </footer>
    </div>

    <div id="modalContainer"></div>
    <div id="appToast" aria-live="polite" aria-atomic="true">
        <div class="app-toast-card info">
            <div class="app-toast-icon"><i class="fa-solid fa-robot"></i></div>
            <div>
                <div class="app-toast-title">Thông báo</div>
                <div class="app-toast-message" id="appToastMessage"></div>
            </div>
        </div>
    </div>

    <!-- ====================== SCRIPTS ====================== -->
    <script>
        (function () {
            // Helper: safe localStorage read
            function lsGet(key, fallback) {
                try { return localStorage.getItem(key) ?? fallback; } catch (e) { return fallback; }
            }
            function lsSet(key, val) {
                try { localStorage.setItem(key, val); } catch (e) { /* ignore */ }
            }

            // Elements
            const sidebarElement = document.getElementById('sidebar');
            const headerElement = document.querySelector('.header-bar');
            const contentElement = document.querySelector('.content');
            const toggleBtn = document.getElementById('toggleBtn');
            const themeSwitch = document.getElementById('themeSwitch');

            // --- Sidebar toggle + persistence ---
            toggleBtn?.addEventListener('click', () => {
                if (window.innerWidth > 992) {
                    sidebarElement.classList.toggle('collapsed');
                    headerElement.classList.toggle('collapsed');
                    contentElement.classList.toggle('collapsed');

                    const isCollapsed = sidebarElement.classList.contains('collapsed');
                    lsSet('sidebarCollapsed', isCollapsed ? 'true' : 'false');
                } else {
                    sidebarElement.classList.toggle('active');
                }
            });

            // On load: restore collapsed
            window.addEventListener('DOMContentLoaded', () => {
                const saved = lsGet('sidebarCollapsed', 'false');
                if (saved === 'true') {
                    sidebarElement.classList.add('collapsed');
                    headerElement.classList.add('collapsed');
                    contentElement.classList.add('collapsed');
                } else {
                    sidebarElement.classList.remove('collapsed');
                    headerElement.classList.remove('collapsed');
                    contentElement.classList.remove('collapsed');
                }
            });

            // --- Header hide/show on scroll (compact) ---
            (function headerScroll() {
                let lastScrollTop = 0;
                let isHidden = false;
                const threshold = 80;
                window.addEventListener('scroll', () => {
                    const currentScroll = window.pageYOffset || document.documentElement.scrollTop;
                    if (currentScroll > lastScrollTop && currentScroll > threshold) {
                        if (!isHidden) {
                            headerElement.classList.remove('show');
                            headerElement.classList.add('hidden');
                            headerElement.style.transform = 'translateY(-110%)';
                            headerElement.style.opacity = '0';
                            isHidden = true;
                        }
                    } else {
                        if (isHidden) {
                            headerElement.classList.remove('hidden');
                            headerElement.classList.add('show');
                            headerElement.style.transform = 'translateY(0)';
                            headerElement.style.opacity = '1';
                            isHidden = false;
                        }
                    }
                    lastScrollTop = Math.max(currentScroll, 0);
                });
            })();

            // --- Ripple on menu items ---
            document.querySelectorAll('.sidebar-menu a').forEach(item => {
                item.addEventListener('click', function (e) {
                    // Create ripple by toggling class (CSS handles ::after transform)
                    this.classList.remove('ripple');
                    void this.offsetWidth;
                    const rect = this.getBoundingClientRect();
                    const x = e.clientX - rect.left;
                    const y = e.clientY - rect.top;
                    this.style.setProperty('--ripple-x', `${x}px`);
                    this.style.setProperty('--ripple-y', `${y}px`);
                    this.style.setProperty('--ripple-size', `${rect.width}px`);
                    this.classList.add('ripple');
                });
            });

            // --- Theme switch behavior (single implementation) ---
            (function themeInit() {
                const knobIcon = themeSwitch.querySelector('.knob i');
                const clickSound = (() => {
                    try { return new Audio("https://cdn.pixabay.com/audio/2022/03/15/audio_c139e5ce37.mp3"); } catch (e) { return null; }
                })();

                const savedTheme = lsGet('theme', 'light');
                applyTheme(savedTheme, false);

                themeSwitch.addEventListener('click', () => {
                    const mode = document.body.classList.contains('dark') ? 'light' : 'dark';
                    if (clickSound) { try { clickSound.currentTime = 0; clickSound.play(); } catch (e) { /* mute fallback */ } }
                    // ripple visual
                    themeSwitch.classList.remove('ripple');
                    void themeSwitch.offsetWidth;
                    themeSwitch.classList.add('ripple');
                    applyTheme(mode, true);
                });

                function applyTheme(mode, animate) {
                    if (mode === 'dark') {
                        document.body.classList.add('dark');
                        themeSwitch.dataset.mode = 'dark';
                        knobIcon.className = 'fa-solid fa-moon';
                    } else {
                        document.body.classList.remove('dark');
                        themeSwitch.dataset.mode = 'light';
                        knobIcon.className = 'fa-solid fa-sun';
                    }
                    if (animate) {
                        themeSwitch.classList.add('switch-animate');
                        setTimeout(() => themeSwitch.classList.remove('switch-animate'), 350);
                    }
                    lsSet('theme', mode);
                }
            })();

            // Expose a small helper to get localStorage theme from server-side (used in body class above)
            window.localStorageTheme = function () {
                try { return localStorage.getItem('theme') || 'light'; } catch (e) { return 'light'; }
            };

        })();
    </script>
    <script>
        // Render HTML and re-run inline/external scripts inside the container.
        window.renderHtml = function (container, html) {
            if (!container) return;
            container.innerHTML = html;
            container.querySelectorAll("script").forEach(oldScript => {
                const newScript = document.createElement("script");
                Array.from(oldScript.attributes).forEach(attr => newScript.setAttribute(attr.name, attr.value));
                newScript.text = oldScript.textContent;
                oldScript.replaceWith(newScript);
            });
        };
    </script>
    <script>
        window.showAppToast = function (message, type) {
            const toast = document.getElementById("appToast");
            const card = toast?.querySelector(".app-toast-card");
            const msg = document.getElementById("appToastMessage");
            if (!toast || !card || !msg) return;

            const safeType = type || "info";
            card.classList.remove("success", "error", "warning", "info");
            card.classList.add(safeType);
            msg.textContent = message || "Đã xử lý";

            const icon = card.querySelector(".app-toast-icon i");
            if (icon) {
                icon.className = safeType === "success"
                    ? "fa-solid fa-user-check"
                    : safeType === "error"
                        ? "fa-solid fa-triangle-exclamation"
                        : safeType === "warning"
                            ? "fa-solid fa-robot"
                            : "fa-solid fa-user-tie";
            }

            toast.classList.add("show");
            clearTimeout(window.__appToastTimer);
            window.__appToastTimer = setTimeout(() => toast.classList.remove("show"), 5000);
        };

        window.refreshContent = function (url) {
            const target = document.querySelector(".content");
            if (!target) return location.reload();
            const fetchUrl = url || window.location.href;
            document.querySelectorAll(".modal.show").forEach(m => {
                const inst = bootstrap.Modal.getInstance(m);
                if (inst) inst.hide();
            });
            document.querySelectorAll(".modal-backdrop").forEach(b => b.remove());
            document.body.classList.remove("modal-open");
            document.body.style.removeProperty("padding-right");
            fetch(fetchUrl, { credentials: "same-origin" })
                .then(r => r.text())
                .then(html => {
                    const wrapper = document.createElement("div");
                    wrapper.innerHTML = html;
                    const next = wrapper.querySelector(".content");
                    const newHtml = next ? next.innerHTML : html;
                    if (window.renderHtml) {
                        window.renderHtml(target, newHtml);
                    } else {
                        target.innerHTML = newHtml;
                    }
                })
                .catch(() => location.reload());
        };

        try {
            const originalAlert = window.alert;
            window.alert = function (message) {
                if (window.showAppToast) {
                    window.showAppToast(message, "info");
                } else {
                    originalAlert(message);
                }
            };
        } catch (e) { }

        try {
            const originalReload = window.location.reload.bind(window.location);
            window.location.reload = function () {
                if (window.refreshContent) {
                    window.refreshContent();
                } else {
                    originalReload();
                }
            };
        } catch (e) { }
    </script>

    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    @RenderSection("Scripts", required: false)
</body>
</html>
