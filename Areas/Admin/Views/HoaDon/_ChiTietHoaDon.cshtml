@model IEnumerable<WebQuanLiCuaHangTapHoa.Areas.Admin.Models.ViewModels.ChiTietItemVM>

@{
    var hd = ViewBag.HoaDon as WebQuanLiCuaHangTapHoa.Models.HoaDon;
    var tongTien = (decimal?)ViewBag.TongTien ?? 0m;

    var qrUrl =
        "https://img.vietqr.io/image/techcombank-3398329567-print.png"
        + "?amount=" + Convert.ToInt64(tongTien)
        + "&addInfo=Thanh+Toan+HD+" + (hd?.MaHD ?? 0);
}

<!-- Modal chi tiết hóa đơn -->
<div class="modal fade" id="modalDetailHD" tabindex="-1">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content" style="border-radius:12px; overflow:hidden;">

            <!-- HEADER -->
            <div class="modal-header bg-info text-white">
                <h5 class="modal-title">
                    <i class="fa-solid fa-file-invoice me-2"></i>
                    Chi tiết hóa đơn #@hd.MaHD
                </h5>
                <button class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <!-- BODY -->
            <div class="modal-body">

                <!-- THÔNG TIN CƠ BẢN -->
                <div class="mb-3 p-3 rounded" style="background:#f8fafc;">
                    <div><strong>Ngày:</strong> @hd.Ngay.ToString("dd/MM/yyyy HH:mm")</div>
                    <div><strong>Khách hàng:</strong> @(hd.KhachHang?.TenKH ?? "-")</div>
                    <div><strong>Nhân viên:</strong> @(hd.NhanVien?.TenNV ?? "-")</div>
                </div>

                <!-- DANH SÁCH SẢN PHẨM -->
                <div class="table-responsive">
                    <table class="table table-bordered align-middle">
                        <thead class="table-light">
                            <tr class="text-center">
                                <th>Mã SP</th>
                                <th>Tên sản phẩm</th>
                                <th width="80">SL</th>
                                <th width="140">Đơn giá</th>
                                <th width="160">Thành tiền</th>
                            </tr>
                        </thead>

                        <tbody>
                            @foreach (var ct in Model)
                            {
                                <tr>
                                    <td class="text-center">@ct.MaSP</td>
                                    <td>@ct.TenSP</td>
                                    <td class="text-center">@ct.SoLuong</td>
                                    <td class="text-end">@String.Format("{0:N0}", ct.DonGia)</td>
                                    <td class="text-end fw-bold text-primary">
                                        @String.Format("{0:N0}", ct.ThanhTien)
                                    </td>
                                </tr>
                            }
                        </tbody>

                        <tfoot>
                            <tr>
                                <th colspan="4" class="text-end">Tổng cộng:</th>
                                <th class="text-end text-danger fw-bold">
                                    @String.Format("{0:N0} ₫", tongTien)
                                </th>
                            </tr>
                        </tfoot>
                    </table>
                </div>

                <hr />

                <!-- QR THANH TOÁN -->
                <div class="text-center">
                    <h5 class="text-primary mb-2">QR Thanh toán tổng hóa đơn</h5>

                    <img src="@qrUrl"
                         alt="QR Thanh toán Techcombank"
                         style="width:220px;border:1px solid #ddd;border-radius:10px;padding:8px;background:#fff;" />

                    <p class="mt-2 small">
                        Ngân hàng: <b>Techcombank</b><br />
                        Số tài khoản: <b>3398329567</b><br />
                        Nội dung: <b>Thanh Toan HD @hd.MaHD</b><br />
                        Số tiền:
                        <span class="text-danger fw-bold">
                            @String.Format("{0:N0} ₫", tongTien)
                        </span>
                    </p>
                </div>

            </div>

            <!-- FOOTER -->
            <div class="modal-footer">
                <a href="@Url.Action("ExportPDF", "HoaDon", new { id = hd.MaHD })"
                   target="_blank"
                   class="btn btn-danger">
                    <i class="fa-solid fa-file-pdf me-1"></i> Xuất PDF
                </a>

                <button class="btn btn-secondary" data-bs-dismiss="modal">
                    Đóng
                </button>
            </div>

        </div>
    </div>
</div>
