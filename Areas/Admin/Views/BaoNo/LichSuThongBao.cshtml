@model PagedList.IPagedList<WebQuanLiCuaHangTapHoa.Models.LichSuThongBao>

@{
    Layout = "~/Areas/Admin/Views/Shared/_LayoutAdmin.cshtml";
    ViewBag.Title = "Lịch sử thông báo";
}

@using (Html.BeginForm())
{
    @Html.AntiForgeryToken()
}

<style>
    .page-title {
        color: #2563eb;
        font-size: 1.8rem;
    }

    .page-title-icon {
        color: #0ea5e9;
        font-size: 1.6rem;
    }

    th, td {
        text-align: center;
        vertical-align: middle;
    }

    /* Pagination giống trang INDEX */
    .pagination {
        display: flex;
        justify-content: center;
        margin: 20px 0;
        flex-wrap: wrap;
        gap: 6px;
    }

        .pagination li {
            list-style: none;
        }

            .pagination li a, .pagination li span {
                display: block;
                padding: 8px 12px;
                border-radius: 8px;
                color: #1e293b;
                border: 1px solid #e2e8f0;
                background: #f8fafc;
                font-weight: 500;
                text-decoration: none;
                transition: all .25s ease;
            }

                .pagination li a:hover {
                    background: #e0f2fe;
                    color: #1d4ed8;
                    transform: translateY(-2px);
                    box-shadow: 0 2px 5px rgba(37,99,235,.2);
                }

            .pagination li.active a {
                background: linear-gradient(90deg,#2563eb,#3b82f6);
                color: white !important;
                border-color: #2563eb;
                box-shadow: 0 2px 8px rgba(37,99,235,.35);
            }

            .pagination li.disabled a {
                opacity: .5;
                pointer-events: none;
            }
</style>

<div class="text-center mb-3">
    <h2 class="page-title fw-bold">
        <i class="fa-solid fa-clock-rotate-left text-warning"></i> Lịch Sử Gửi Thông Báo
    </h2>
</div>

<div class="mb-3">
    <a href="@Url.Action("Index", "BaoNo", new { area = "Admin" })" class="btn btn-outline-secondary">
        <i class="fa-solid fa-arrow-left"></i> Quay lại danh sách
    </a>
</div>

<form class="card p-3 mb-3 shadow-sm" method="get">
    <div class="row g-3">
        <div class="col-md-3"><label>Từ ngày</label><input type="date" name="from" class="form-control" value="@ViewBag.From" /></div>
        <div class="col-md-3"><label>Đến ngày</label><input type="date" name="to" class="form-control" value="@ViewBag.To" /></div>
        <div class="col-md-3"><label>Tên khách</label><input type="text" name="name" class="form-control" placeholder="Nhập tên..." value="@ViewBag.Name" /></div>
        <div class="col-md-2">
            <label>Loại</label>
            <select name="type" class="form-select">
                <option value="">Tất cả</option>
                <option value="EMAIL" @(ViewBag.Type == "EMAIL" ? "selected" : "")>Email</option>
                <option value="SMS" @(ViewBag.Type == "SMS" ? "selected" : "")>SMS</option>
            </select>
        </div>
        <div class="col-md-1 d-flex align-items-end"><button class="btn btn-primary w-100"><i class="fa-solid fa-filter"></i></button></div>
    </div>
</form>

<div class="card shadow-sm">
    <table class="table table-bordered table-hover mb-0">
        <thead class="table-light">
            <tr>
                <th>Mã KH</th>
                <th>Tên KH</th>
                <th>Số nợ</th>
                <th>Thời gian nợ</th>
                <th>Loại</th>
                <th>Nội dung</th>
                <th>Ngày gửi</th>
                <th>Hành động</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var x in Model)
            {
                <tr>
                    <td>@x.BaoNo.KhachHang.MaKH</td>
                    <td>@x.BaoNo.KhachHang.TenKH</td>
                    <td class="text-danger fw-bold">@String.Format("{0:N0} ₫", x.BaoNo.SoTien)</td>
                    <td>@((DateTime.Now - x.BaoNo.NgayTao).Days) ngày</td>
                    <td>
                        @if (x.Loai == "EMAIL")
                        {<span class="badge bg-primary">Email</span> }
                        else
                        { <span class="badge bg-success">SMS</span>}
                    </td>
                    <td>@x.NoiDung</td>
                    <td>@x.NgayGui.ToString("dd/MM/yyyy HH:mm")</td>
                    <td>
                        <a href="@Url.Action("SuaTinNhan", "BaoNo", new { area = "Admin", id = x.Id })" class="btn btn-primary btn-sm me-1">
                            <i class="fa-solid fa-pen-to-square"></i>
                        </a>
                        <button class="btn btn-success btn-sm btn-resend" data-id="@x.Id">
                            <i class="fa-solid fa-paper-plane"></i>
                        </button>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    <!-- ========================= PAGINATION GIỐNG INDEX ========================= -->
    <div class="card-footer bg-white text-center">
        <ul class="pagination">

            @{
                bool isFirst = Model.PageNumber == 1;
                bool isLast = Model.PageNumber == Model.PageCount;
            }

            <!-- << -->
            <li class="@(isFirst ? "disabled" : "")">
                <a href="@(isFirst ? "#" : Url.Action("LichSuThongBao", new { page = 1 }))">&laquo;&laquo;</a>
            </li>

            <!-- < -->
            <li class="@(isFirst ? "disabled" : "")">
                <a href="@(isFirst ? "#" : Url.Action("LichSuThongBao", new { page = Model.PageNumber - 1 }))">&laquo;</a>
            </li>

            <!-- số trang -->
            @for (int i = 1; i <= Model.PageCount; i++)
            {
                <li class="@(Model.PageNumber == i ? "active" : "")">
                    <a href="@Url.Action("LichSuThongBao", new { page = i })">@i</a>
                </li>
            }

            <!-- > -->
            <li class="@(isLast ? "disabled" : "")">
                <a href="@(isLast ? "#" : Url.Action("LichSuThongBao", new { page = Model.PageNumber + 1 }))">&raquo;</a>
            </li>

            <!-- >> -->
            <li class="@(isLast ? "disabled" : "")">
                <a href="@(isLast ? "#" : Url.Action("LichSuThongBao", new { page = Model.PageCount }))">&raquo;&raquo;</a>
            </li>

        </ul>
    </div>
</div>

<script>
    function getAntiForgeryToken() {
        var el = document.querySelector('input[name="__RequestVerificationToken"]');
        return el ? el.value : '';
    }

    document.addEventListener("click", async e => {
        let resend = e.target.closest(".btn-resend");
        if (resend) {
            let id = resend.dataset.id;
            const token = getAntiForgeryToken();
            let res = await fetch("/Admin/BaoNo/GuiLai", {
                method: "POST",
                headers: { "Content-Type": "application/x-www-form-urlencoded" },
                body: "__RequestVerificationToken=" + encodeURIComponent(token) + "&id=" + encodeURIComponent(id)
            });
            let data = await res.json();
            alert(data.message);
        }
    });
</script>
