@{
    Layout = null;
    var msg = TempData["ForgotSuccess"] ?? TempData["ErrorForgot"] ?? "";
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>Lấy lại mật khẩu</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />

    <style>
body{
    height:100vh; margin:0; display:flex; justify-content:center; align-items:center;
    background:radial-gradient(circle at 20% 20%, #eef2ff,#fafafa);
    font-family:'Inter',sans-serif;
}
.box{
    width:380px; padding:36px; border-radius:20px;
    background:white; box-shadow:0 20px 60px rgba(0,0,0,.12);
    animation:fade .5s ease;
}
@@keyframes fade{from{opacity:0;transform:translateY(20px);}to{opacity:1;transform:none;}}

.btn-ultra{
    width:100%; padding:12px; border-radius:12px; border:none;
    background:linear-gradient(90deg,#7c3aed,#4f46e5); color:white; font-weight:700;
}
.form-control{border-radius:12px;padding:12px;}
    </style>
</head>

<body>

    <div class="box">
        <h4 class="fw-bold text-center mb-2">Khôi phục mật khẩu</h4>
        <p class="text-center text-secondary mb-3">Nhập email hoặc tài khoản của bạn</p>

        @if (!string.IsNullOrEmpty(msg.ToString()))
        {
            <div class="alert alert-info">@msg</div>
        }

        @using (Html.BeginForm("ForgotPassword", "AdminAuth", FormMethod.Post, new { area = "Admin" }))
        {
            @Html.AntiForgeryToken()
            <input name="account" class="form-control mb-3" required placeholder="Email hoặc tài khoản" />
            <button class="btn-ultra"><i class="fa-solid fa-paper-plane me-2"></i>Gửi yêu cầu</button>
        }

        <div class="text-center mt-3">
            <a href="@Url.Action("Login","AdminAuth",new{area="Admin"})" class="text-decoration-none" style="color:#4f46e5;font-weight:600;">
                Quay lại đăng nhập
            </a>
        </div>
    </div>

</body>
</html>
