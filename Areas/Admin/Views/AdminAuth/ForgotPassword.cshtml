@{
    Layout = null;
    var msg = TempData["ForgotMsg"] ?? "";
}
<!doctype html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>Quên mật khẩu — ULTRA PRO MAX</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <style>
        html, body {
            height: 100%;
            margin: 0;
            font-family: Inter,system-ui;
        }

        body {
            display: flex;
            align-items: center;
            justify-content: center;
            background: linear-gradient(180deg,#f6fbff,#eef6ff);
        }

        .card {
            width: 440px;
            padding: 24px;
            border-radius: 14px;
            background: white;
            box-shadow: 0 30px 80px rgba(16,24,40,0.08);
        }

        .btn-primary-ultra {
            background: linear-gradient(90deg,#7c3aed,#06b6d4);
            color: #fff;
            border: none;
            padding: 10px 14px;
            border-radius: 10px;
            font-weight: 700;
        }
    </style>
</head>
<body>
    <div class="card">
        <h5>Khôi phục mật khẩu</h5>
        <p class="text-muted">Nhập tên đăng nhập hoặc email. Hệ thống sẽ gửi hướng dẫn đặt lại mật khẩu đến email (nếu có).</p>

       

        @using (Html.BeginForm("ForgotPassword", "AdminAuth", FormMethod.Post, new { area = "Admin" }))
        {
            @Html.AntiForgeryToken()
            <div class="mb-3">
                <label class="form-label small">Email hoặc tên đăng nhập</label>
                <input name="account" class="form-control" placeholder="Email hoặc tên đăng nhập" required />
            </div>
            <div class="d-flex justify-content-end">
                <a href="@Url.Action("Login","AdminAuth", new { area = "Admin" })" class="btn btn-light me-2">Quay lại</a>
                <button class="btn btn-primary-ultra">Gửi hướng dẫn</button>
            </div>
        }
    </div>
</body>
</html>
