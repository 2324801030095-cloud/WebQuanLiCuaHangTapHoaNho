@* File: Areas/Admin/Views/KhachHang/_ThemKhachHang.cshtml *@
@model WebQuanLiCuaHangTapHoa.Models.KhachHang

<div class="modal fade" id="modalAddKH" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-md modal-dialog-centered">
        <div class="modal-content" style="border-radius:14px; overflow:hidden;">
            <div class="modal-header" style="background:linear-gradient(90deg,#10b981,#34d399); color:white;">
                <h5 class="modal-title"><i class="fa-solid fa-user-plus me-2"></i>Thêm khách hàng</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Đóng"></button>
            </div>

            <div class="modal-body" style="background:linear-gradient(180deg,#ffffff,#f8fafc);">
                @using (Html.BeginForm("Them", "KhachHang", FormMethod.Post, new { id = "formAddKH" }))
                {
                    <div class="row g-3">
                        <div class="col-12">
                            @Html.LabelFor(m => m.TenKH, "Tên khách hàng")
                            @Html.TextBoxFor(m => m.TenKH, new { @class = "form-control", required = "required", placeholder = "Nhập tên khách hàng" })
                        </div>

                        <div class="col-md-6">
                            @Html.LabelFor(m => m.SoDT, "Số điện thoại")
                            @Html.TextBoxFor(m => m.SoDT, new { @class = "form-control", placeholder = "Số điện thoại" })
                        </div>

                        <div class="col-md-6">
                            @Html.LabelFor(m => m.DiaChi, "Địa chỉ")
                            @Html.TextBoxFor(m => m.DiaChi, new { @class = "form-control", placeholder = "Địa chỉ (tùy chọn)" })
                        </div>
                    </div>
                }
            </div>

            <div class="modal-footer" style="background:transparent; border-top:0;">
                <button class="btn btn-apple btn-apple-secondary" data-bs-dismiss="modal">Đóng</button>
                <button class="btn btn-add-apple" id="btnSaveAddKH" type="button"><i class="fa-solid fa-check me-1"></i> Lưu</button>
            </div>
        </div>
    </div>
</div>

<script>
    (function () {

        const btn = document.getElementById('btnSaveAddKH');
        if (!btn) return;

        btn.addEventListener('click', function () {

            const form = document.getElementById('formAddKH');
            const fd = new FormData(form);

            showLoading();

            fetch('/Admin/KhachHang/Them', {
                method: 'POST',
                body: fd
            })
                .then(r => r.json())
                .then(data => {

                    hideLoading();

                    // Lỗi? → Giữ nguyên Swal của bạn
                    if (!data.success) {
                        Swal.fire({ icon: 'error', title: 'Lỗi', text: data.message });
                        return;
                    }

                    // Đóng modal KH
                    const modal = bootstrap.Modal.getInstance(document.getElementById('modalAddKH'));
                    if (modal) modal.hide();

                    // ⭐ Trả KH mới về modal Thêm Hóa Đơn
                    if (window.returnNewKH) {
                        window.returnNewKH(data.maKH, data.tenKH);
                    }

                })
                .catch(err => {
                    hideLoading();
                    Swal.fire({ icon: 'error', title: 'Lỗi', text: 'Lỗi khi thêm khách hàng.' });
                    console.error(err);
                });

        });

    })();
</script>
